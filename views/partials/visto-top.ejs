<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title><%= title %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      :root{
        --bg: #0b1020;
        --panel: rgba(2,6,23,.82);
        --panel2: rgba(3,7,18,.82);
        --stroke: rgba(148,163,184,.16);
        --text: #e5e7eb;
        --muted: #94a3b8;
        --brand1: #4f46e5;
        --brand2: #22c55e;
        --warn: #f59e0b;
        --bad: #fca5a5;
      }
      *{box-sizing:border-box}
      body{
        margin:0;
        font-family: system-ui,-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
        background:
          radial-gradient(1200px 700px at 10% -10%, rgba(79,70,229,.35), transparent 60%),
          radial-gradient(900px 500px at 85% 0%, rgba(34,197,94,.25), transparent 55%),
          radial-gradient(900px 600px at 45% 110%, rgba(14,165,233,.16), transparent 55%),
          var(--bg);
        color: var(--text);
      }
      a{color:inherit; text-decoration:none}
      .shell{
        display:grid;
        grid-template-columns: 240px minmax(0,1fr);
        min-height:100vh;
      }
      .sidebar{
        padding:0;
        border-right:1px solid var(--stroke);
        background: linear-gradient(180deg, rgba(2,6,23,.98) 0%, rgba(3,7,18,.96) 100%);
        position:sticky;
        top:0;
        height:100vh;
        display:flex;
        flex-direction:column;
        overflow:hidden;
      }
      .brand{
        display:flex; gap:12px; align-items:center;
        padding:18px 14px 16px;
        border-bottom:1px solid var(--stroke);
        flex-shrink:0;
      }
      .logo{
        flex-shrink:0;
        width:36px; height:36px; border-radius:10px;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
        box-shadow: 0 0 22px rgba(79,70,229,.55), 0 4px 14px rgba(0,0,0,.45);
        display:flex; align-items:center; justify-content:center;
      }
      .brand-text h1{
        font-size:13px; margin:0; font-weight:700;
        letter-spacing:.2px; color:var(--text);
      }
      .brand-text p{
        margin:2px 0 0; color:var(--muted); font-size:11px;
      }
      .nav-wrap{
        flex:1;
        padding:8px 8px 10px;
        overflow-y:auto;
        scrollbar-width:none;
      }
      .nav-wrap::-webkit-scrollbar{ display:none }
      .nav-section{
        font-size:10px;
        font-weight:700;
        letter-spacing:.09em;
        text-transform:uppercase;
        color: rgba(148,163,184,.38);
        padding:14px 10px 5px;
        margin:0;
      }
      .nav{
        display:flex; flex-direction:column; gap:2px;
      }
      .nav a{
        display:flex; align-items:center; gap:10px;
        padding:9px 10px;
        border-radius:10px;
        color: var(--muted);
        background: transparent;
        font-size:13px;
        transition: color .14s, background .14s;
      }
      .nav a:hover{
        color: var(--text);
        background: rgba(148,163,184,.07);
      }
      .nav a.active{
        color: var(--text);
        background: linear-gradient(90deg, rgba(79,70,229,.18), rgba(34,197,94,.05));
        box-shadow: inset 3px 0 0 var(--brand1);
      }
      .nav-icon{
        flex-shrink:0;
        width:15px; height:15px;
        opacity:.5;
        transition: opacity .14s;
      }
      .nav a:hover .nav-icon,
      .nav a.active .nav-icon{ opacity:1; }
      .nav-label{ flex:1; font-weight:500; }
      .nav-badge{
        font-size:10px;
        padding:1px 7px;
        border-radius:999px;
        background: rgba(148,163,184,.10);
        color: rgba(148,163,184,.5);
        font-weight:600;
        letter-spacing:.02em;
      }
      .nav a.active .nav-badge{
        background: rgba(79,70,229,.22);
        color: rgba(167,165,255,.85);
      }
      .side-foot{
        flex-shrink:0;
        padding:10px 10px 12px;
        border-top:1px solid var(--stroke);
        display:flex; flex-direction:column; gap:5px;
      }
      .sf-row{
        display:flex; align-items:center; gap:8px;
        padding:6px 8px;
        border-radius:8px;
        background: rgba(148,163,184,.05);
        font-size:11px;
        color:var(--muted);
        overflow:hidden;
      }
      .sf-dot{
        width:7px; height:7px;
        border-radius:50%;
        flex-shrink:0;
      }
      .sf-dot.ok  { background:#22c55e; box-shadow:0 0 6px rgba(34,197,94,.7) }
      .sf-dot.err { background:#ef4444; box-shadow:0 0 6px rgba(239,68,68,.7) }
      .sf-dot.info{ background:#38bdf8; box-shadow:0 0 6px rgba(56,189,248,.6) }
      .sf-label{ flex:1; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
      .pill{
        display:inline-flex; align-items:center; gap:8px;
        padding:6px 10px;
        border-radius:999px;
        border:1px solid var(--stroke);
        background: rgba(2,6,23,.55);
        font-size:12px;
        color: var(--muted);
      }
      .main{
        padding:18px 18px 50px;
      }
      .topbar{
        display:flex; align-items:center; justify-content:space-between; gap:12px;
        padding:14px 16px;
        border:1px solid var(--stroke);
        border-radius:16px;
        background: linear-gradient(180deg, rgba(2,6,23,.82), rgba(2,6,23,.60));
        backdrop-filter: blur(10px);
      }
      .topbar h2{
        margin:0;
        font-size:16px;
        letter-spacing:.2px;
      }
      .topbar p{margin:0; color:var(--muted); font-size:12px}
      .content{
        margin-top:14px;
      }
      .card{
        border:1px solid var(--stroke);
        border-radius:16px;
        background: linear-gradient(180deg, rgba(2,6,23,.82), rgba(3,7,18,.74));
        box-shadow: 0 18px 55px rgba(0,0,0,.35);
      }
      .card .hd{
        padding:14px 16px;
        border-bottom:1px solid rgba(148,163,184,.12);
        display:flex; align-items:flex-start; justify-content:space-between; gap:12px;
      }
      .card .hd h3{margin:0; font-size:14px}
      .card .hd span{color:var(--muted); font-size:12px}
      .card .bd{padding:14px 16px;}
      .grid{
        display:grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 12px 14px;
      }
      label{display:block; font-size:12px; color:var(--muted); margin-bottom:6px}
      input, textarea{
        width:100%;
        border-radius:12px;
        border:1px solid rgba(148,163,184,.18);
        padding:10px 12px;
        background: rgba(2,6,23,.65);
        color: var(--text);
        outline:none;
      }
      input:focus, textarea:focus{border-color: rgba(79,70,229,.55); box-shadow:0 0 0 3px rgba(79,70,229,.16)}
      .btn{
        display:inline-flex; align-items:center; justify-content:center; gap:8px;
        border-radius:999px;
        padding:10px 16px;
        border:0;
        cursor:pointer;
        font-weight:700;
        color:white;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
      }
      .btn.secondary{
        background: rgba(2,6,23,.55);
        border:1px solid rgba(148,163,184,.18);
        color: var(--text);
        font-weight:700;
      }
      .btn:disabled{opacity:.6; cursor:progress}
      pre{
        margin:0;
        border:1px solid rgba(148,163,184,.14);
        border-radius:14px;
        padding:12px 12px;
        background: rgba(2,6,23,.62);
        overflow:auto;
        max-height: 320px;
        font-size:12px;
      }
      table{
        width:100%;
        border-collapse:collapse;
        font-size:12px;
      }
      th,td{
        padding:8px 10px;
        border-bottom:1px solid rgba(148,163,184,.12);
        white-space:nowrap;
        text-align:left;
      }
      th{color: var(--muted); font-weight:700}
      .scroll-x{overflow-x:auto}
      .badge{
        display:inline-flex; align-items:center;
        padding:2px 10px;
        border-radius:999px;
        font-size:11px;
        border:1px solid rgba(148,163,184,.18);
        background: rgba(148,163,184,.08);
        color: var(--text);
      }
      .status-wrap{display:flex; flex-direction:column; gap:6px; min-width:150px}
      .progress{
        height:8px;
        border-radius:999px;
        border:1px solid rgba(148,163,184,.14);
        background: rgba(2,6,23,.55);
        overflow:hidden;
      }
      .progress > div{
        height:100%;
        background: linear-gradient(90deg, var(--brand1), var(--brand2));
        width:0%;
      }
      .status-line{display:flex; align-items:center; justify-content:space-between; gap:10px}
      .status-line strong{font-size:11px}
      .muted{color:var(--muted)}
      .warn{color:var(--warn)}
      .bad{color:var(--bad)}

      @media (max-width: 960px){
        .shell{grid-template-columns: 1fr}
        .sidebar{position:relative; height:auto; max-height:none}
        .nav-wrap{overflow-y:visible}
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <div class="brand">
          <div class="logo">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg"><path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/></svg>
          </div>
          <div class="brand-text">
            <h1>Visto • EVP Gateway</h1>
            <p>Web UI + Proxy APIs</p>
          </div>
        </div>
        <div class="nav-wrap">
          <p class="nav-section">Payments</p>
          <nav class="nav">
            <a class="<%= active === 'payment' ? 'active' : '' %>" href="/payment">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
              <span class="nav-label">Payment</span>
              <span class="nav-badge">v1</span>
            </a>
            <a class="<%= active === 'payment-v2' ? 'active' : '' %>" href="/payment-v2">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/><line x1="8" y1="15" x2="10" y2="15"/><line x1="12" y1="15" x2="16" y2="15"/></svg>
              <span class="nav-label">Payment v2</span>
              <span class="nav-badge" style="color:#86efac;border-color:rgba(134,239,172,.3);background:rgba(134,239,172,.08);">tid</span>
            </a>
            <a class="<%= active === 'status' ? 'active' : '' %>" href="/payment-status">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <span class="nav-label">Payment Status</span>
              <span class="nav-badge">check</span>
            </a>
            <a class="<%= active === 'report' ? 'active' : '' %>" href="/evp-payment-report">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
              <span class="nav-label">EVP Report</span>
              <span class="nav-badge">sql</span>
            </a>
          </nav>
          <p class="nav-section">Tools</p>
          <nav class="nav">
            <a class="<%= active === 'webhook' ? 'active' : '' %>" href="/webhook">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              <span class="nav-label">Webhook</span>
              <span class="nav-badge">sim</span>
            </a>
            <a class="<%= active === 'loadtest' ? 'active' : '' %>" href="/loadtest">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              <span class="nav-label">Load Test</span>
              <span class="nav-badge">browser</span>
            </a>
          </nav>
          <p class="nav-section">Admin</p>
          <nav class="nav">
            <a class="<%= active === 'merchant-list' ? 'active' : '' %>" href="/admin/merchants">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              <span class="nav-label">Merchants</span>
              <span class="nav-badge">list</span>
            </a>
            <a class="<%= active === 'merchant' ? 'active' : '' %>" href="/admin/merchant">
              <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
              <span class="nav-label">Merchant Config</span>
              <span class="nav-badge">db</span>
            </a>
          </nav>
        </div>
        <div class="side-foot">
          <div class="sf-row">
            <span class="sf-dot <%= merchant ? 'ok' : 'err' %>"></span>
            <span class="sf-label">DB: <%= merchant ? merchant.Terminal_ID : 'No Active' %></span>
          </div>
          <div class="sf-row">
            <span class="sf-dot info"></span>
            <span class="sf-label">API: /api/*</span>
          </div>
          <form method="post" action="/logout" style="margin:4px 0 0;padding:0 8px;">
            <button type="submit" class="btn secondary" style="width:100%;font-size:12px;padding:8px 12px;font-weight:600;">
              ออกจากระบบ
            </button>
          </form>
        </div>
      </aside>
      <main class="main">
        <div class="topbar">
          <div>
            <h2><%= pageTitle %></h2>
            <p><%= pageSubtitle %></p>
          </div>
          <div style="display:flex;gap:10px;align-items:center;">
            <% if (!merchant) { %>
              <span class="badge bad">No Active Merchant</span>
            <% } else { %>
              <span class="badge">Terminal_ID: <%= merchant.Terminal_ID %></span>
            <% } %>
          </div>
        </div>
        <div class="content">
