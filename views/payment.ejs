<script>
(function () {
  /* ── server-injected merchant values ── */
  var M = {
    baseUrl:    '<%- BASE_URL %>',
    terminal:   '<%- TERMINAL %>',
    partner:    '<%- PARTNER %>',
    apiKey:     '<%- API_KEY %>',
    evpUrl:     '<%- EVP_URL %>'
  };

  /* read live form values */
  function vals() {
    return {
      amount:    document.getElementById('f_amount')        ? document.getElementById('f_amount').value        : '300',
      currCode:  document.getElementById('f_currCode')      ? document.getElementById('f_currCode').value      : '764',
      orderId:   document.getElementById('f_orderId')       ? document.getElementById('f_orderId').value       : 'ORD-001',
      customerId:document.getElementById('f_customerId')    ? document.getElementById('f_customerId').value    : 'CUST-001',
      txnRef:    document.getElementById('f_transactionRef')? document.getElementById('f_transactionRef').value: 'TXN-001'
    };
  }

  function esc(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  /* ── code generators ── */
  function genNodejs(v) {
    return [
      '<span class="t-cmt">// npm install axios</span>',
      '<span class="t-kw">const</span> <span class="t-var">axios</span> = <span class="t-fn">require</span>(<span class="t-str">\'axios\'</span>);',
      '',
      '<span class="t-kw">const</span> <span class="t-var">payload</span> = {',
      '  <span class="t-prop">partner_id</span>:        <span class="t-str">\'' + esc(M.partner) + '\'</span>,',
      '  <span class="t-prop">transaction_type</span>: <span class="t-str">\'SALE\'</span>,',
      '  <span class="t-prop">amount</span>:            <span class="t-num">' + esc(v.amount) + '</span>,',
      '  <span class="t-prop">curr_code</span>:         <span class="t-num">' + esc(v.currCode) + '</span>,',
      '  <span class="t-prop">reference</span>: {',
      '    <span class="t-prop">order_id</span>:        <span class="t-str">\'' + esc(v.orderId) + '\'</span>,',
      '    <span class="t-prop">customer_id</span>:     <span class="t-str">\'' + esc(v.customerId) + '\'</span>,',
      '    <span class="t-prop">transaction_ref</span>: <span class="t-str">\'' + esc(v.txnRef) + '\'</span>',
      '  }',
      '};',
      '',
      '<span class="t-kw">async function</span> <span class="t-fn">createPayment</span>() {',
      '  <span class="t-kw">const</span> { <span class="t-var">data</span> } = <span class="t-kw">await</span> <span class="t-var">axios</span>.<span class="t-fn">post</span>(',
      '    <span class="t-str">\'' + esc(M.evpUrl) + '\'</span>,',
      '    <span class="t-var">payload</span>,',
      '    { <span class="t-prop">headers</span>: {',
      '        <span class="t-str">\'Content-Type\'</span>: <span class="t-str">\'application/json\'</span>,',
      '        <span class="t-str">\'x-api-key\'</span>:     <span class="t-str">\'' + esc(M.apiKey) + '\'</span>',
      '      }',
      '    }',
      '  );',
      '  <span class="t-var">console</span>.<span class="t-fn">log</span>(<span class="t-var">data</span>);',
      '}',
      '',
      '<span class="t-fn">createPayment</span>();'
    ].join('\n');
  }

  function genJs(v) {
    return [
      '<span class="t-kw">const</span> <span class="t-var">payload</span> = {',
      '  <span class="t-prop">partner_id</span>:        <span class="t-str">\'' + esc(M.partner) + '\'</span>,',
      '  <span class="t-prop">transaction_type</span>: <span class="t-str">\'SALE\'</span>,',
      '  <span class="t-prop">amount</span>:            <span class="t-num">' + esc(v.amount) + '</span>,',
      '  <span class="t-prop">curr_code</span>:         <span class="t-num">' + esc(v.currCode) + '</span>,',
      '  <span class="t-prop">reference</span>: {',
      '    <span class="t-prop">order_id</span>:        <span class="t-str">\'' + esc(v.orderId) + '\'</span>,',
      '    <span class="t-prop">customer_id</span>:     <span class="t-str">\'' + esc(v.customerId) + '\'</span>,',
      '    <span class="t-prop">transaction_ref</span>: <span class="t-str">\'' + esc(v.txnRef) + '\'</span>',
      '  }',
      '};',
      '',
      '<span class="t-kw">const</span> <span class="t-var">res</span> = <span class="t-kw">await</span> <span class="t-fn">fetch</span>(<span class="t-str">\'' + esc(M.evpUrl) + '\'</span>, {',
      '  <span class="t-prop">method</span>:  <span class="t-str">\'POST\'</span>,',
      '  <span class="t-prop">headers</span>: {',
      '    <span class="t-str">\'Content-Type\'</span>: <span class="t-str">\'application/json\'</span>,',
      '    <span class="t-str">\'x-api-key\'</span>:     <span class="t-str">\'' + esc(M.apiKey) + '\'</span>',
      '  },',
      '  <span class="t-prop">body</span>: <span class="t-type">JSON</span>.<span class="t-fn">stringify</span>(<span class="t-var">payload</span>)',
      '});',
      '',
      '<span class="t-kw">const</span> <span class="t-var">data</span> = <span class="t-kw">await</span> <span class="t-var">res</span>.<span class="t-fn">json</span>();',
      '<span class="t-var">console</span>.<span class="t-fn">log</span>(<span class="t-var">data</span>);'
    ].join('\n');
  }

  function genPython(v) {
    return [
      '<span class="t-cmt"># pip install requests</span>',
      '<span class="t-kw">import</span> <span class="t-var">requests</span>',
      '<span class="t-kw">import</span> <span class="t-var">json</span>',
      '',
      '<span class="t-var">url</span> = <span class="t-str">"' + esc(M.evpUrl) + '"</span>',
      '',
      '<span class="t-var">headers</span> = {',
      '    <span class="t-str">"Content-Type"</span>: <span class="t-str">"application/json"</span>,',
      '    <span class="t-str">"x-api-key"</span>:     <span class="t-str">"' + esc(M.apiKey) + '"</span>',
      '}',
      '',
      '<span class="t-var">payload</span> = {',
      '    <span class="t-str">"partner_id"</span>:        <span class="t-str">"' + esc(M.partner) + '"</span>,',
      '    <span class="t-str">"transaction_type"</span>: <span class="t-str">"SALE"</span>,',
      '    <span class="t-str">"amount"</span>:            <span class="t-num">' + esc(v.amount) + '</span>,',
      '    <span class="t-str">"curr_code"</span>:         <span class="t-num">' + esc(v.currCode) + '</span>,',
      '    <span class="t-str">"reference"</span>: {',
      '        <span class="t-str">"order_id"</span>:        <span class="t-str">"' + esc(v.orderId) + '"</span>,',
      '        <span class="t-str">"customer_id"</span>:     <span class="t-str">"' + esc(v.customerId) + '"</span>,',
      '        <span class="t-str">"transaction_ref"</span>: <span class="t-str">"' + esc(v.txnRef) + '"</span>',
      '    }',
      '}',
      '',
      '<span class="t-var">response</span> = <span class="t-var">requests</span>.<span class="t-fn">post</span>(<span class="t-var">url</span>, <span class="t-prop">headers</span>=<span class="t-var">headers</span>, <span class="t-prop">json</span>=<span class="t-var">payload</span>)',
      '<span class="t-fn">print</span>(<span class="t-var">response</span>.<span class="t-fn">json</span>())'
    ].join('\n');
  }

  function genCsharp(v) {
    return [
      '<span class="t-kw">using</span> <span class="t-type">System</span>.<span class="t-type">Net</span>.<span class="t-type">Http</span>;',
      '<span class="t-kw">using</span> <span class="t-type">System</span>.<span class="t-type">Net</span>.<span class="t-type">Http</span>.<span class="t-type">Json</span>;',
      '<span class="t-kw">using</span> <span class="t-type">System</span>.<span class="t-type">Text</span>.<span class="t-type">Json</span>.<span class="t-type">Serialization</span>;',
      '',
      '<span class="t-kw">var</span> <span class="t-var">client</span> = <span class="t-kw">new</span> <span class="t-type">HttpClient</span>();',
      '<span class="t-var">client</span>.<span class="t-prop">DefaultRequestHeaders</span>.<span class="t-fn">Add</span>(<span class="t-str">"x-api-key"</span>, <span class="t-str">"' + esc(M.apiKey) + '"</span>);',
      '',
      '<span class="t-kw">var</span> <span class="t-var">payload</span> = <span class="t-kw">new</span> {',
      '    partner_id        = <span class="t-str">"' + esc(M.partner) + '"</span>,',
      '    transaction_type  = <span class="t-str">"SALE"</span>,',
      '    amount            = <span class="t-num">' + esc(v.amount) + '</span>,',
      '    curr_code         = <span class="t-num">' + esc(v.currCode) + '</span>,',
      '    reference = <span class="t-kw">new</span> {',
      '        order_id        = <span class="t-str">"' + esc(v.orderId) + '"</span>,',
      '        customer_id     = <span class="t-str">"' + esc(v.customerId) + '"</span>,',
      '        transaction_ref = <span class="t-str">"' + esc(v.txnRef) + '"</span>',
      '    }',
      '};',
      '',
      '<span class="t-kw">var</span> <span class="t-var">response</span> = <span class="t-kw">await</span> <span class="t-var">client</span>.<span class="t-fn">PostAsJsonAsync</span>(',
      '    <span class="t-str">"' + esc(M.evpUrl) + '"</span>,',
      '    <span class="t-var">payload</span>',
      ');',
      '',
      '<span class="t-kw">var</span> <span class="t-var">result</span> = <span class="t-kw">await</span> <span class="t-var">response</span>.<span class="t-prop">Content</span>.<span class="t-fn">ReadAsStringAsync</span>();',
      '<span class="t-type">Console</span>.<span class="t-fn">WriteLine</span>(<span class="t-var">result</span>);'
    ].join('\n');
  }

  function genCpp(v) {
    return [
      '<span class="t-cmt">// g++ -std=c++17 -lcurl -o payment payment.cpp</span>',
      '<span class="t-kw">#include</span> <span class="t-str">&lt;iostream&gt;</span>',
      '<span class="t-kw">#include</span> <span class="t-str">&lt;string&gt;</span>',
      '<span class="t-kw">#include</span> <span class="t-str">&lt;curl/curl.h&gt;</span>',
      '',
      '<span class="t-kw">static</span> <span class="t-type">size_t</span> <span class="t-fn">WriteCallback</span>(<span class="t-kw">void</span>* <span class="t-var">contents</span>, <span class="t-type">size_t</span> <span class="t-var">size</span>,',
      '                          <span class="t-type">size_t</span> <span class="t-var">nmemb</span>, <span class="t-type">std::string</span>* <span class="t-var">s</span>) {',
      '    <span class="t-var">s</span>-><span class="t-fn">append</span>((<span class="t-kw">char</span>*)<span class="t-var">contents</span>, <span class="t-var">size</span> * <span class="t-var">nmemb</span>);',
      '    <span class="t-kw">return</span> <span class="t-var">size</span> * <span class="t-var">nmemb</span>;',
      '}',
      '',
      '<span class="t-type">int</span> <span class="t-fn">main</span>() {',
      '    <span class="t-type">std::string</span> <span class="t-var">body</span> = <span class="t-type">std::string</span>(<span class="t-str">"{</span>\\n<span class="t-str">"</span>)',
      '      + <span class="t-str">"  \\"partner_id\\": \\"'        + esc(M.partner)    + '\\"," </span>\\n',
      '      + <span class="t-str">"  \\"transaction_type\\": \\"SALE\\"," </span>\\n',
      '      + <span class="t-str">"  \\"amount\\": '              + esc(v.amount)     + ',"</span>\\n',
      '      + <span class="t-str">"  \\"curr_code\\": '           + esc(v.currCode)   + ',"</span>\\n',
      '      + <span class="t-str">"  \\"reference\\": {"</span>\\n',
      '      + <span class="t-str">"    \\"order_id\\": \\"'       + esc(v.orderId)    + '\\"," </span>\\n',
      '      + <span class="t-str">"    \\"customer_id\\": \\"'    + esc(v.customerId) + '\\"," </span>\\n',
      '      + <span class="t-str">"    \\"transaction_ref\\": \\"'+ esc(v.txnRef)     + '\\"" </span>\\n',
      '      + <span class="t-str">"  }}"</span>;',
      '',
      '    <span class="t-type">CURL</span>* <span class="t-var">curl</span> = <span class="t-fn">curl_easy_init</span>();',
      '    <span class="t-type">std::string</span> <span class="t-var">resp</span>;',
      '    <span class="t-kw">if</span> (<span class="t-var">curl</span>) {',
      '        <span class="t-type">struct curl_slist</span>* <span class="t-var">hdrs</span> = <span class="t-kw">nullptr</span>;',
      '        <span class="t-var">hdrs</span> = <span class="t-fn">curl_slist_append</span>(<span class="t-var">hdrs</span>, <span class="t-str">"Content-Type: application/json"</span>);',
      '        <span class="t-var">hdrs</span> = <span class="t-fn">curl_slist_append</span>(<span class="t-var">hdrs</span>, <span class="t-str">"x-api-key: ' + esc(M.apiKey) + '"</span>);',
      '        <span class="t-fn">curl_easy_setopt</span>(<span class="t-var">curl</span>, <span class="t-type">CURLOPT_URL</span>,        <span class="t-str">"' + esc(M.evpUrl) + '"</span>);',
      '        <span class="t-fn">curl_easy_setopt</span>(<span class="t-var">curl</span>, <span class="t-type">CURLOPT_HTTPHEADER</span>,  <span class="t-var">hdrs</span>);',
      '        <span class="t-fn">curl_easy_setopt</span>(<span class="t-var">curl</span>, <span class="t-type">CURLOPT_POSTFIELDS</span>,  <span class="t-var">body</span>.<span class="t-fn">c_str</span>());',
      '        <span class="t-fn">curl_easy_setopt</span>(<span class="t-var">curl</span>, <span class="t-type">CURLOPT_WRITEFUNCTION</span>, <span class="t-var">WriteCallback</span>);',
      '        <span class="t-fn">curl_easy_setopt</span>(<span class="t-var">curl</span>, <span class="t-type">CURLOPT_WRITEDATA</span>,    &<span class="t-var">resp</span>);',
      '        <span class="t-fn">curl_easy_perform</span>(<span class="t-var">curl</span>);',
      '        <span class="t-fn">curl_easy_cleanup</span>(<span class="t-var">curl</span>);',
      '    }',
      '    <span class="t-type">std::cout</span> <span class="t-op">&lt;&lt;</span> <span class="t-var">resp</span> <span class="t-op">&lt;&lt;</span> <span class="t-type">std::endl</span>;',
      '    <span class="t-kw">return</span> <span class="t-num">0</span>;',
      '}'
    ].join('\n');
  }

  function genPhp(v) {
    return [
      '<span class="t-op">&lt;?php</span>',
      '',
      '<span class="t-var">$payload</span> = [',
      '    <span class="t-str">\'partner_id\'</span>        => <span class="t-str">\'' + esc(M.partner) + '\'</span>,',
      '    <span class="t-str">\'transaction_type\'</span> => <span class="t-str">\'SALE\'</span>,',
      '    <span class="t-str">\'amount\'</span>            => <span class="t-num">' + esc(v.amount) + '</span>,',
      '    <span class="t-str">\'curr_code\'</span>         => <span class="t-num">' + esc(v.currCode) + '</span>,',
      '    <span class="t-str">\'reference\'</span>         => [',
      '        <span class="t-str">\'order_id\'</span>        => <span class="t-str">\'' + esc(v.orderId) + '\'</span>,',
      '        <span class="t-str">\'customer_id\'</span>     => <span class="t-str">\'' + esc(v.customerId) + '\'</span>,',
      '        <span class="t-str">\'transaction_ref\'</span> => <span class="t-str">\'' + esc(v.txnRef) + '\'</span>',
      '    ]',
      '];',
      '',
      '<span class="t-var">$ch</span> = <span class="t-fn">curl_init</span>(<span class="t-str">\'' + esc(M.evpUrl) + '\'</span>);',
      '<span class="t-fn">curl_setopt_array</span>(<span class="t-var">$ch</span>, [',
      '    <span class="t-type">CURLOPT_RETURNTRANSFER</span> => <span class="t-kw">true</span>,',
      '    <span class="t-type">CURLOPT_POST</span>           => <span class="t-kw">true</span>,',
      '    <span class="t-type">CURLOPT_POSTFIELDS</span>     => <span class="t-fn">json_encode</span>(<span class="t-var">$payload</span>),',
      '    <span class="t-type">CURLOPT_HTTPHEADER</span>     => [',
      '        <span class="t-str">\'Content-Type: application/json\'</span>,',
      '        <span class="t-str">\'x-api-key: ' + esc(M.apiKey) + '\'</span>',
      '    ]',
      ']);',
      '',
      '<span class="t-var">$response</span> = <span class="t-fn">curl_exec</span>(<span class="t-var">$ch</span>);',
      '<span class="t-fn">curl_close</span>(<span class="t-var">$ch</span>);',
      '<span class="t-fn">var_dump</span>(<span class="t-fn">json_decode</span>(<span class="t-var">$response</span>, <span class="t-kw">true</span>));'
    ].join('\n');
  }

  function genHtml(v) {
    return [
      '<span class="t-op">&lt;!</span><span class="t-kw">DOCTYPE</span> <span class="t-type">html</span><span class="t-op">&gt;</span>',
      '<span class="t-op">&lt;</span><span class="t-kw">html</span> <span class="t-prop">lang</span>=<span class="t-str">"en"</span><span class="t-op">&gt;</span><span class="t-op">&lt;</span><span class="t-kw">head</span><span class="t-op">&gt;</span>',
      '  <span class="t-op">&lt;</span><span class="t-kw">meta</span> <span class="t-prop">charset</span>=<span class="t-str">"UTF-8"</span><span class="t-op">&gt;</span>',
      '  <span class="t-op">&lt;</span><span class="t-kw">title</span><span class="t-op">&gt;</span>EVP Payment<span class="t-op">&lt;/</span><span class="t-kw">title</span><span class="t-op">&gt;</span>',
      '<span class="t-op">&lt;/</span><span class="t-kw">head</span><span class="t-op">&gt;&lt;</span><span class="t-kw">body</span><span class="t-op">&gt;</span>',
      '',
      '<span class="t-op">&lt;</span><span class="t-kw">button</span> <span class="t-prop">onclick</span>=<span class="t-str">"createPayment()"</span><span class="t-op">&gt;</span>Pay<span class="t-op">&lt;/</span><span class="t-kw">button</span><span class="t-op">&gt;</span>',
      '<span class="t-op">&lt;</span><span class="t-kw">pre</span> <span class="t-prop">id</span>=<span class="t-str">"result"</span><span class="t-op">&gt;&lt;/</span><span class="t-kw">pre</span><span class="t-op">&gt;</span>',
      '',
      '<span class="t-op">&lt;</span><span class="t-kw">script</span><span class="t-op">&gt;</span>',
      '<span class="t-kw">async function</span> <span class="t-fn">createPayment</span>() {',
      '  <span class="t-kw">const</span> <span class="t-var">payload</span> = {',
      '    <span class="t-prop">partner_id</span>:        <span class="t-str">\'' + esc(M.partner) + '\'</span>,',
      '    <span class="t-prop">transaction_type</span>: <span class="t-str">\'SALE\'</span>,',
      '    <span class="t-prop">amount</span>:            <span class="t-num">' + esc(v.amount) + '</span>,',
      '    <span class="t-prop">curr_code</span>:         <span class="t-num">' + esc(v.currCode) + '</span>,',
      '    <span class="t-prop">reference</span>: {',
      '      <span class="t-prop">order_id</span>:        <span class="t-str">\'' + esc(v.orderId) + '\'</span>,',
      '      <span class="t-prop">customer_id</span>:     <span class="t-str">\'' + esc(v.customerId) + '\'</span>,',
      '      <span class="t-prop">transaction_ref</span>: <span class="t-str">\'' + esc(v.txnRef) + '\'</span>',
      '    }',
      '  };',
      '  <span class="t-kw">const</span> <span class="t-var">res</span> = <span class="t-kw">await</span> <span class="t-fn">fetch</span>(<span class="t-str">\'' + esc(M.evpUrl) + '\'</span>, {',
      '    <span class="t-prop">method</span>:  <span class="t-str">\'POST\'</span>,',
      '    <span class="t-prop">headers</span>: {',
      '      <span class="t-str">\'Content-Type\'</span>: <span class="t-str">\'application/json\'</span>,',
      '      <span class="t-str">\'x-api-key\'</span>:     <span class="t-str">\'' + esc(M.apiKey) + '\'</span>',
      '    },',
      '    <span class="t-prop">body</span>: <span class="t-type">JSON</span>.<span class="t-fn">stringify</span>(<span class="t-var">payload</span>)',
      '  });',
      '  <span class="t-kw">const</span> <span class="t-var">data</span> = <span class="t-kw">await</span> <span class="t-var">res</span>.<span class="t-fn">json</span>();',
      '  <span class="t-var">document</span>.<span class="t-fn">getElementById</span>(<span class="t-str">\'result\'</span>).<span class="t-prop">textContent</span>',
      '    = <span class="t-type">JSON</span>.<span class="t-fn">stringify</span>(<span class="t-var">data</span>, <span class="t-kw">null</span>, <span class="t-num">2</span>);',
      '}',
      '<span class="t-op">&lt;/</span><span class="t-kw">script</span><span class="t-op">&gt;&lt;/</span><span class="t-kw">body</span><span class="t-op">&gt;&lt;/</span><span class="t-kw">html</span><span class="t-op">&gt;</span>'
    ].join('\n');
  }

  /* plain-text version for copying */
  function rawPayload(v) {
    return {
      partner_id:       M.partner,
      transaction_type: 'SALE',
      amount:           Number(v.amount)   || 0,
      curr_code:        Number(v.currCode) || 764,
      reference: {
        order_id:        v.orderId,
        customer_id:     v.customerId,
        transaction_ref: v.txnRef
      }
    };
  }

  function rawNodejs(v) {
    var p = JSON.stringify(rawPayload(v), null, 2);
    return "const axios = require('axios');\n\nconst payload = " + p + ";\n\n"
      + "async function createPayment() {\n"
      + "  const { data } = await axios.post(\n"
      + "    '" + M.evpUrl + "',\n"
      + "    payload,\n"
      + "    { headers: { 'Content-Type': 'application/json', 'x-api-key': '" + M.apiKey + "' } }\n"
      + "  );\n  console.log(data);\n}\n\ncreatePayment();";
  }
  function rawJs(v) {
    var p = JSON.stringify(rawPayload(v), null, 2);
    return "const payload = " + p + ";\n\n"
      + "const res = await fetch('" + M.evpUrl + "', {\n"
      + "  method: 'POST',\n"
      + "  headers: { 'Content-Type': 'application/json', 'x-api-key': '" + M.apiKey + "' },\n"
      + "  body: JSON.stringify(payload)\n});\n\n"
      + "const data = await res.json();\nconsole.log(data);";
  }
  function rawPython(v) {
    return "import requests\n\nurl = \"" + M.evpUrl + "\"\n\n"
      + "headers = {\n    \"Content-Type\": \"application/json\",\n    \"x-api-key\": \"" + M.apiKey + "\"\n}\n\n"
      + "payload = {\n"
      + "    \"partner_id\": \"" + M.partner + "\",\n"
      + "    \"transaction_type\": \"SALE\",\n"
      + "    \"amount\": " + v.amount + ",\n"
      + "    \"curr_code\": " + v.currCode + ",\n"
      + "    \"reference\": {\n"
      + "        \"order_id\": \"" + v.orderId + "\",\n"
      + "        \"customer_id\": \"" + v.customerId + "\",\n"
      + "        \"transaction_ref\": \"" + v.txnRef + "\"\n"
      + "    }\n}\n\n"
      + "response = requests.post(url, headers=headers, json=payload)\nprint(response.json())";
  }
  function rawCsharp(v) {
    return "using System.Net.Http;\nusing System.Net.Http.Json;\n\nvar client = new HttpClient();\nclient.DefaultRequestHeaders.Add(\"x-api-key\", \"" + M.apiKey + "\");\n\n"
      + "var payload = new {\n    partner_id = \"" + M.partner + "\",\n    transaction_type = \"SALE\",\n    amount = " + v.amount + ",\n    curr_code = " + v.currCode + ",\n"
      + "    reference = new { order_id = \"" + v.orderId + "\", customer_id = \"" + v.customerId + "\", transaction_ref = \"" + v.txnRef + "\" }\n};\n\n"
      + "var response = await client.PostAsJsonAsync(\"" + M.evpUrl + "\", payload);\nvar result = await response.Content.ReadAsStringAsync();\nConsole.WriteLine(result);";
  }
  function rawCpp(v) {
    return '#include <iostream>\n#include <string>\n#include <curl/curl.h>\n\nstatic size_t WriteCallback(void* c, size_t s, size_t n, std::string* b) { b->append((char*)c, s*n); return s*n; }\n\nint main() {\n'
      + '    std::string body = R"({"partner_id":"' + M.partner + '","transaction_type":"SALE","amount":' + v.amount + ',"curr_code":' + v.currCode
      + ',"reference":{"order_id":"' + v.orderId + '","customer_id":"' + v.customerId + '","transaction_ref":"' + v.txnRef + '"}})"; \n\n'
      + '    CURL* curl = curl_easy_init();\n    std::string resp;\n    if (curl) {\n'
      + '        struct curl_slist* hdrs = nullptr;\n'
      + '        hdrs = curl_slist_append(hdrs, "Content-Type: application/json");\n'
      + '        hdrs = curl_slist_append(hdrs, "x-api-key: ' + M.apiKey + '");\n'
      + '        curl_easy_setopt(curl, CURLOPT_URL, "' + M.evpUrl + '");\n'
      + '        curl_easy_setopt(curl, CURLOPT_HTTPHEADER, hdrs);\n'
      + '        curl_easy_setopt(curl, CURLOPT_POSTFIELDS, body.c_str());\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, WriteCallback);\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEDATA, &resp);\n'
      + '        curl_easy_perform(curl);\n        curl_easy_cleanup(curl);\n    }\n'
      + '    std::cout << resp << std::endl;\n    return 0;\n}';
  }
  function rawPhp(v) {
    return "<?php\n\n\$payload = [\n    'partner_id'        => '" + M.partner + "',\n    'transaction_type' => 'SALE',\n    'amount'            => " + v.amount + ",\n    'curr_code'         => " + v.currCode + ",\n"
      + "    'reference'         => [\n        'order_id'        => '" + v.orderId + "',\n        'customer_id'     => '" + v.customerId + "',\n        'transaction_ref' => '" + v.txnRef + "'\n    ]\n];\n\n"
      + "\$ch = curl_init('" + M.evpUrl + "');\ncurl_setopt_array(\$ch, [\n    CURLOPT_RETURNTRANSFER => true,\n    CURLOPT_POST           => true,\n    CURLOPT_POSTFIELDS     => json_encode(\$payload),\n    CURLOPT_HTTPHEADER     => ['Content-Type: application/json', 'x-api-key: " + M.apiKey + "']\n]);\n\n\$response = curl_exec(\$ch);\ncurl_close(\$ch);\nvar_dump(json_decode(\$response, true));";
  }
  function rawHtml(v) {
    var p = JSON.stringify(rawPayload(v), null, 4);
    return '<!DOCTYPE html>\n<html><head><meta charset="UTF-8"><title>EVP Payment</title></head><body>\n<button onclick="createPayment()">Pay</button>\n<pre id="result"></pre>\n<script>\nasync function createPayment() {\n  const payload = ' + p + ';\n  const res = await fetch("' + M.evpUrl + '", {\n    method: "POST",\n    headers: { "Content-Type": "application/json", "x-api-key": "' + M.apiKey + '" },\n    body: JSON.stringify(payload)\n  });\n  const data = await res.json();\n  document.getElementById("result").textContent = JSON.stringify(data, null, 2);\n}\n<\/script></body></html>';
  }

  var rawFns = {
    nodejs: rawNodejs, js: rawJs, python: rawPython,
    csharp: rawCsharp, cpp: rawCpp, php: rawPhp, html: rawHtml
  };
  var genFns = {
    nodejs: genNodejs, js: genJs, python: genPython,
    csharp: genCsharp, cpp: genCpp, php: genPhp, html: genHtml
  };

  var activeLang = 'nodejs';

  function updateCode() {
    var v = vals();
    Object.keys(genFns).forEach(function (lang) {
      var el = document.getElementById('code-' + lang);
      if (el) el.innerHTML = genFns[lang](v);
    });
  }

  /* tab switching */
  document.querySelectorAll('.lang-tab').forEach(function (tab) {
    tab.addEventListener('click', function () {
      document.querySelectorAll('.lang-tab').forEach(function (t) { t.classList.remove('active'); });
      document.querySelectorAll('.lang-body').forEach(function (b) { b.classList.remove('active'); });
      tab.classList.add('active');
      activeLang = tab.getAttribute('data-lang');
      var body = document.getElementById('lang-' + activeLang);
      if (body) body.classList.add('active');
    });
  });

  /* copy buttons */
  document.querySelectorAll('.code-copy-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var targetId = btn.getAttribute('data-target');
      var lang = targetId ? targetId.replace('code-', '') : activeLang;
      var v = vals();
      var raw = rawFns[lang] ? rawFns[lang](v) : '';
      if (!raw) return;
      navigator.clipboard.writeText(raw).then(function () {
        btn.classList.add('copied');
        var orig = btn.innerHTML;
        btn.innerHTML = btn.innerHTML.replace(/Copy/i, 'Copied!');
        setTimeout(function () { btn.classList.remove('copied'); btn.innerHTML = orig; }, 1800);
      });
    });
  });

  /* live update on form change */
  ['f_amount','f_currCode','f_orderId','f_customerId','f_transactionRef'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', updateCode);
  });

  /* initial render */
  updateCode();
})();
</script>

