  .t-op   { color: #94a3b8; }   /* operator */
  .t-prop { color: #93c5fd; }   /* property */
  .t-anno { color: #fbbf24; }   /* annotation / decorator */
</style>

<div class="code-panel">
  <div class="code-panel-head">
    <div>
      <h4>Code Examples</h4>
      <p>ตัวอย่างโค้ดสำหรับเรียก <code style="font-size:12px;color:#93c5fd;">POST /api/payments</code> ผ่าน Gateway (แอปนี้) — อัปเดตอัตโนมัติตามค่าฟอร์ม</p>
    </div>
    <div style="display:flex;flex-direction:column;align-items:flex-end;gap:6px;">
      <span style="font-size:11px;padding:3px 9px;border-radius:6px;background:rgba(34,197,94,.08);color:#86efac;border:1px solid #14532d;">
        Gateway: <span style="color:#86efac;font-family:monospace;"><%= PROXY_PAYMENTS_URL %></span>
      </span>
      <span style="font-size:10px;padding:2px 8px;border-radius:6px;background:rgba(148,163,184,.06);color:#64748b;border:1px solid #1f2937;">
        Direct EVP: <span style="color:#94a3b8;font-family:monospace;"><%= EVP_URL %></span>
      </span>
    </div>
  </div>

  <div class="lang-tabs">
    <div class="lang-tab active" data-lang="curl">
      <span class="lang-dot" style="background:#f97316;"></span>cURL
    </div>
    <div class="lang-tab" data-lang="nodejs">
      <span class="lang-dot" style="background:#68a063;"></span>Node.js
    </div>
    <div class="lang-tab" data-lang="js">
      <span class="lang-dot" style="background:#f7df1e;"></span>JavaScript
    </div>
    <div class="lang-tab" data-lang="python">
      <span class="lang-dot" style="background:#3776ab;"></span>Python
    </div>
    <div class="lang-tab" data-lang="csharp">
      <span class="lang-dot" style="background:#512bd4;"></span>C#
    </div>
    <div class="lang-tab" data-lang="cpp">
      <span class="lang-dot" style="background:#00599c;"></span>C++
    </div>
    <div class="lang-tab" data-lang="php">
      <span class="lang-dot" style="background:#8892be;"></span>PHP
    </div>
    <div class="lang-tab" data-lang="html">
      <span class="lang-dot" style="background:#e34c26;"></span>HTML
    </div>
  </div>

  <!-- cURL -->
  <div class="lang-body active" id="lang-curl">
    <div class="code-toolbar">
      <div class="curl-subtabs" style="margin:0;">
        <button type="button" class="curl-subtab active" data-code-ex="proxy">Proxy (Gateway)</button>
        <button type="button" class="curl-subtab" data-code-ex="direct">Direct EVP</button>
