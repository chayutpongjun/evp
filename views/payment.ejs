    return 'using System.Net.Http;\nusing System.Net.Http.Json;\nusing System.Net.Http.Headers;\n\nvar client = new HttpClient();\n'
      + 'client.DefaultRequestHeaders.Add("x-api-key", "' + M.apiKey + '");\n\n'
      + 'var payload = new {\n    partner_id = "' + M.partner + '",\n    transaction_type = "SALE",\n'
      + '    amount = ' + (Number(v.amount) || 0) + ',\n    curr_code = ' + (Number(v.currCode) || 764) + ',\n'
      + '    reference = new {\n        order_id = "' + v.orderId + '",\n        customer_id = "' + v.customerId + '",\n        transaction_ref = "' + v.txnRef + '"\n    }\n};\n\n'
      + 'var response = await client.PostAsJsonAsync("' + M.evpUrl + '", payload);\n'
      + 'var result = await response.Content.ReadAsStringAsync();\nConsole.WriteLine(result);\n';
  }
  function rawCsharpEvpStatus(v) {
    var base = rawEvpPath();
    return 'using System.Net.Http;\n\nvar client = new HttpClient();\n'
      + 'client.DefaultRequestHeaders.Add("x-api-key", "' + M.apiKey + '");\n'
      + 'var paymentId = "{evp_payment_id}";\nvar url = "' + base + '" + paymentId;\n\n'
      + 'var response = await client.GetAsync(url);\nvar result = await response.Content.ReadAsStringAsync();\nConsole.WriteLine(result);\n';
  }

  function rawCppDirect(v) {
    var u = M.evpUrl;
    var body = '{"partner_id":"' + M.partner + '","transaction_type":"SALE","amount":' + (Number(v.amount) || 0) + ',"curr_code":' + (Number(v.currCode) || 764) + ',"reference":{"order_id":"' + v.orderId + '","customer_id":"' + v.customerId + '","transaction_ref":"' + v.txnRef + '"}}';
    return '#include <iostream>\n#include <string>\n#include <curl/curl.h>\n\nstatic size_t WriteCallback(void* c, size_t s, size_t n, std::string* b) { b->append((char*)c, s*n); return s*n; }\n\nint main() {\n'
      + '    std::string body = R"(' + body + ')";\n    CURL* curl = curl_easy_init();\n    std::string resp;\n    if (curl) {\n'
      + '        struct curl_slist* hdrs = nullptr;\n'
      + '        hdrs = curl_slist_append(hdrs, "Content-Type: application/json");\n'
      + '        hdrs = curl_slist_append(hdrs, "x-api-key: ' + M.apiKey + '");\n'
      + '        curl_easy_setopt(curl, CURLOPT_URL, "' + u + '");\n'
      + '        curl_easy_setopt(curl, CURLOPT_HTTPHEADER, hdrs);\n'
      + '        curl_easy_setopt(curl, CURLOPT_POSTFIELDS, body.c_str());\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, WriteCallback);\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEDATA, &resp);\n'
      + '        curl_easy_perform(curl);\n        curl_easy_cleanup(curl);\n    }\n'
      + '    std::cout << resp << std::endl;\n    return 0;\n}';
  }
  function rawCppEvpStatus(v) {
    var base = rawEvpPath();
    return '#include <iostream>\n#include <string>\n#include <curl/curl.h>\n\nstatic size_t WriteCallback(void* c, size_t s, size_t n, std::string* b) { b->append((char*)c, s*n); return s*n; }\n\nint main() {\n'
      + '    std::string paymentId = "{evp_payment_id}";\n    std::string url = "' + base + '" + paymentId;\n'
      + '    CURL* curl = curl_easy_init();\n    std::string resp;\n    if (curl) {\n'
      + '        struct curl_slist* hdrs = nullptr;\n'
      + '        hdrs = curl_slist_append(hdrs, "x-api-key: ' + M.apiKey + '");\n'
      + '        curl_easy_setopt(curl, CURLOPT_URL, url.c_str());\n'
      + '        curl_easy_setopt(curl, CURLOPT_HTTPGET, 1L);\n'
      + '        curl_easy_setopt(curl, CURLOPT_HTTPHEADER, hdrs);\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, WriteCallback);\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEDATA, &resp);\n'
      + '        curl_easy_perform(curl);\n        curl_easy_cleanup(curl);\n    }\n'
      + '    std::cout << resp << std::endl;\n    return 0;\n}';
  }

  function rawPhpDirect(v) {
    var u = M.evpUrl;
    return "<?php\n\n$payload = [\n    'partner_id' => '" + M.partner + "',\n    'transaction_type' => 'SALE',\n"
      + "    'amount' => " + (Number(v.amount) || 0) + ",\n    'curr_code' => " + (Number(v.currCode) || 764) + ",\n"
      + "    'reference' => [\n        'order_id' => '" + v.orderId + "',\n        'customer_id' => '" + v.customerId + "',\n        'transaction_ref' => '" + v.txnRef + "'\n    ]\n];\n\n"
      + "$ch = curl_init('" + u + "');\ncurl_setopt_array($ch, [\n    CURLOPT_RETURNTRANSFER => true,\n    CURLOPT_POST => true,\n"
      + "    CURLOPT_POSTFIELDS => json_encode($payload),\n    CURLOPT_HTTPHEADER => ['Content-Type: application/json', 'x-api-key: " + M.apiKey + "']\n]);\n\n"
      + "$response = curl_exec($ch);\ncurl_close($ch);\nvar_dump(json_decode($response, true));";
  }
  function rawPhpEvpStatus(v) {
    var base = rawEvpPath();
    return "<?php\n\n$paymentId = '{evp_payment_id}';\n$url = '" + base + "' . $paymentId;\n\n"
      + "$ch = curl_init($url);\ncurl_setopt_array($ch, [\n    CURLOPT_RETURNTRANSFER => true,\n"
      + "    CURLOPT_HTTPHEADER => ['x-api-key: " + M.apiKey + "']\n]);\n\n$response = curl_exec($ch);\ncurl_close($ch);\necho $response;\n";
  }

  function rawHtmlDirect(v) {
    var u = M.evpUrl;
    var body = JSON.stringify({
      partner_id:       M.partner,
      transaction_type: 'SALE',
      amount:           Number(v.amount) || 0,
      curr_code:        Number(v.currCode) || 764,
      reference: {
        order_id:        v.orderId,
        customer_id:     v.customerId,
        transaction_ref: v.txnRef
      }
    }, null, 4);
    return '<!DOCTYPE html>\n<html><head><meta charset="UTF-8"></head><body>\n<button onclick="pay()">Pay</button>\n<pre id="r"></pre>\n<script>\nasync function pay() {\n  const res = await fetch("' + u + '", {\n    method: "POST",\n    headers: { "Content-Type": "application/json", "x-api-key": "' + M.apiKey + '" },\n    body: JSON.stringify(' + body + ')\n  });\n  document.getElementById("r").textContent = JSON.stringify(await res.json(), null, 2);\n}\n<\/script></body></html>';
  }
  function rawHtmlEvpStatus(v) {
    var base = rawEvpPath();
    return '<!DOCTYPE html>\n<html><head><meta charset="UTF-8"></head><body>\n<button onclick="loadStatus()">Get status</button>\n<pre id="r"></pre>\n<script>\nasync function loadStatus() {\n  const paymentId = \'{evp_payment_id}\';\n  const url = ' + JSON.stringify(base) + ' + paymentId;\n  const res = await fetch(url, { headers: { "x-api-key": "' + M.apiKey + '" } });\n  document.getElementById("r").textContent = JSON.stringify(await res.json(), null, 2);\n}\n<\/script></body></html>';
  }

  var rawSepGw = '\n\n# --- Get payment status (Gateway) ---\n\n';
  var rawSepDir = '\n\n# --- Get payment status (Direct EVP) ---\n\n';
  var rawSepGwJs = '\n\n// --- Get payment status (Gateway) ---\n\n';
  var rawSepDirJs = '\n\n// --- Get payment status (Direct EVP) ---\n\n';

  var rawFns = {
    curl: {
      proxy:  function (v) { return rawCurlCreate(v) + rawSepGw + rawCurlStatus(v); },
      direct: function (v) { return rawCurlDirectCreate(v) + rawSepDir + rawCurlDirectStatus(v); }
    },
    nodejs: {
      proxy:  function (v) { return rawNodejs(v) + rawSepGwJs + rawNodejsStatus(v); },
      direct: function (v) { return rawNodejsDirect(v) + rawSepDirJs + rawNodejsEvpStatus(v); }
    },
    js: {
      proxy:  function (v) { return rawJs(v) + rawSepGwJs + rawJsStatus(v); },
      direct: function (v) { return rawJsDirect(v) + rawSepDirJs + rawJsEvpStatus(v); }
    },
    python: {
      proxy:  function (v) { return rawPython(v) + rawSepGwJs + rawPythonStatus(v); },
      direct: function (v) { return rawPythonDirect(v) + rawSepDirJs + rawPythonEvpStatus(v); }
    },
    csharp: {
      proxy:  function (v) { return rawCsharp(v) + rawSepGwJs + rawCsharpStatus(v); },
      direct: function (v) { return rawCsharpDirect(v) + rawSepDirJs + rawCsharpEvpStatus(v); }
    },
    cpp: {
      proxy:  function (v) { return rawCpp(v) + rawSepGwJs + rawCppStatus(v); },
      direct: function (v) { return rawCppDirect(v) + rawSepDirJs + rawCppEvpStatus(v); }
    },
    php: {
      proxy:  function (v) { return rawPhp(v) + rawSepGwJs + rawPhpStatus(v); },
      direct: function (v) { return rawPhpDirect(v) + rawSepDirJs + rawPhpEvpStatus(v); }
    },
    html: {
      proxy:  function (v) { return rawHtml(v) + rawSepGwJs + rawHtmlStatus(v); },
      direct: function (v) { return rawHtmlDirect(v) + rawSepDirJs + rawHtmlEvpStatus(v); }
    }
  };

  var genFns = {
    curl: {
      proxy:  function (v) { return genCurlCreate(v) + sepCurl(true) + genCurlStatus(v); },
      direct: function (v) { return genCurlDirectCreate(v) + sepCurl(false) + genCurlDirectStatus(v); }
    },
    nodejs: {
      proxy:  function (v) { return genNodejs(v) + sepCode(true) + genNodejsStatus(v); },
      direct: function (v) { return genNodejsDirect(v) + sepCode(false) + genNodejsEvpStatus(v); }
    },
    js: {
      proxy:  function (v) { return genJs(v) + sepCode(true) + genJsStatus(v); },
      direct: function (v) { return genJsDirect(v) + sepCode(false) + genJsEvpStatus(v); }
    },
    python: {
      proxy:  function (v) { return genPython(v) + sepCode(true) + genPythonStatus(v); },
      direct: function (v) { return genPythonDirect(v) + sepCode(false) + genPythonEvpStatus(v); }
    },
    csharp: {
      proxy:  function (v) { return genCsharp(v) + sepCode(true) + genCsharpStatus(v); },
      direct: function (v) { return genCsharpDirect(v) + sepCode(false) + genCsharpEvpStatus(v); }
    },
    cpp: {
      proxy:  function (v) { return genCpp(v) + sepCode(true) + genCppStatus(v); },
      direct: function (v) { return genCppDirect(v) + sepCode(false) + genCppEvpStatus(v); }
    },
    php: {
      proxy:  function (v) { return genPhp(v) + sepCode(true) + genPhpStatus(v); },
      direct: function (v) { return genPhpDirect(v) + sepCode(false) + genPhpEvpStatus(v); }
    },
    html: {
      proxy:  function (v) { return genHtml(v) + sepCode(true) + genHtmlStatus(v); },
      direct: function (v) { return genHtmlDirect(v) + sepCode(false) + genHtmlEvpStatus(v); }
    }
  };

  var activeLang = 'curl';
  var activeCodeEx = 'proxy';

  function setCodeExMode(mode) {
    activeCodeEx = mode;
    document.querySelectorAll('[data-code-ex]').forEach(function (t) {
      t.classList.toggle('active', t.getAttribute('data-code-ex') === mode);
    });
    ['curl','nodejs','js','python','csharp','cpp','php','html'].forEach(function (lang) {
      var p = document.getElementById('code-' + lang + '-proxy');
      var d = document.getElementById('code-' + lang + '-direct');
      if (p) p.style.display = mode === 'proxy' ? '' : 'none';
      if (d) d.style.display = mode === 'direct' ? '' : 'none';
    });
  }

  function updateCode() {
    var v = vals();
    ['curl','nodejs','js','python','csharp','cpp','php','html'].forEach(function (lang) {
      var pe = document.getElementById('code-' + lang + '-proxy');
      var de = document.getElementById('code-' + lang + '-direct');
      var g = genFns[lang];
      if (g && pe) pe.innerHTML = g.proxy(v);
      if (g && de) de.innerHTML = g.direct(v);
    });
  }

  /* tab switching */
  document.querySelectorAll('.lang-tab').forEach(function (tab) {
    tab.addEventListener('click', function () {
      document.querySelectorAll('.lang-tab').forEach(function (t) { t.classList.remove('active'); });
      document.querySelectorAll('.lang-body').forEach(function (b) { b.classList.remove('active'); });
      tab.classList.add('active');
      activeLang = tab.getAttribute('data-lang');
      var body = document.getElementById('lang-' + activeLang);
      if (body) body.classList.add('active');
    });
  });

  document.querySelectorAll('[data-code-ex]').forEach(function (st) {
    st.addEventListener('click', function () {
      setCodeExMode(st.getAttribute('data-code-ex'));
    });
  });

  /* copy buttons */
  document.querySelectorAll('.code-copy-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var targetId = btn.getAttribute('data-target');
      var lang = targetId ? targetId.replace('code-', '') : activeLang;
      var v = vals();
      var raw = '';
      if (rawFns[lang] && rawFns[lang][activeCodeEx]) {
        raw = rawFns[lang][activeCodeEx](v);
      }
      if (!raw) return;
      navigator.clipboard.writeText(raw).then(function () {
        btn.classList.add('copied');
        var orig = btn.innerHTML;
        btn.innerHTML = btn.innerHTML.replace(/Copy/i, 'Copied!');
        setTimeout(function () { btn.classList.remove('copied'); btn.innerHTML = orig; }, 1800);
      });
    });
  });

  /* live update on form change */
  ['f_amount','f_currCode','f_orderId','f_customerId','f_transactionRef'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', updateCode);
  });

  /* initial render */
  updateCode();
})();
</script>

