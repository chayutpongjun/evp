<%- include('partials/visto-top', {
  title: 'Webhook • EVP Gateway',
  active: 'webhook',
  pageTitle: 'Webhook',
  pageSubtitle: 'จำลองการเรียก webhook เข้า gateway และดู response/status',
  merchant
}) %>

<%
  var W_TERMINAL = merchant ? merchant.Terminal_ID : 'TID001';
  var W_API_KEY  = merchant ? merchant.ApiKey      : 'YOUR_API_KEY';
  var W_APP_URL  = (typeof appUrl !== 'undefined' && appUrl) ? String(appUrl).replace(/\/$/, '') : 'http://localhost:3000';
  var W_SAMPLE_PID = (payments && payments.length && payments[0].Res_Payment_ID) ? payments[0].Res_Payment_ID : '';
%>

<style>
  .wh-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    align-items: start;
  }
  @media (max-width: 900px) { .wh-layout { grid-template-columns: 1fr; } }

  /* ── Request Inspector ── */
  .req-panel {
    border: 1px solid #111827;
    border-radius: 14px;
    background: #060b14;
    overflow: hidden;
    font-size: 13px;
  }
  .req-panel-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 11px 14px;
    border-bottom: 1px solid #111827;
    background: #080e1a;
  }
  .req-panel-head > span {
    font-size: 12px; font-weight: 700; color: #9ca3af;
    letter-spacing: .4px; text-transform: uppercase;
  }
  .req-url-bar {
    display: flex; align-items: center;
    padding: 10px 14px;
    border-bottom: 1px solid #111827;
    background: #0a1020;
  }
  .req-method {
    font-size: 11px; font-weight: 800;
    padding: 4px 9px; border-radius: 6px;
    background: rgba(34,197,94,.14); color: #22c55e;
    border: 1px solid rgba(34,197,94,.25);
    margin-right: 10px; flex-shrink: 0; letter-spacing: .5px;
  }
  .req-url {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 11px; color: #60a5fa; word-break: break-all; line-height: 1.5;
  }
  .req-tabs {
    display: flex; border-bottom: 1px solid #111827;
    padding: 0 14px; background: #080e1a; gap: 2px;
  }
  .req-tab {
    padding: 8px 12px; font-size: 12px; font-weight: 600; color: #4b5563;
    cursor: pointer; border-bottom: 2px solid transparent;
    transition: color .15s, border-color .15s; user-select: none;
  }
  .req-tab.active { color: #e5e7eb; border-color: #00e676; }
  .req-tab:hover:not(.active) { color: #9ca3af; }
  .req-body { display: none; padding: 12px 14px; }
  .req-body.active { display: block; }
  .req-headers { width: 100%; border-collapse: collapse; font-size: 12px; }
  .req-headers td { padding: 5px 8px; border-bottom: 1px solid #0d1117; vertical-align: top; }
  .req-headers td:first-child { color: #9ca3af; white-space: nowrap; font-weight: 600; width: 42%; }
  .req-headers td:last-child { color: #e5e7eb; font-family: monospace; word-break: break-all; }
  .req-json {
    background: #020609; border: 1px solid #0d1117; border-radius: 8px;
    padding: 12px; font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 11.5px; line-height: 1.65; overflow-x: auto;
    white-space: pre; color: #d1d5db; max-height: 300px; overflow-y: auto;
  }
  .json-key  { color: #93c5fd; }
  .json-str  { color: #86efac; }
  .json-num  { color: #fde68a; }
  .json-null { color: #f87171; }
  .req-curl {
    background: #020609; border: 1px solid #0d1117; border-radius: 8px;
    padding: 12px 14px; font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 11px; line-height: 1.8; overflow-x: auto;
    white-space: pre-wrap; word-break: break-all; color: #d1d5db;
  }
  .curl-cmd  { color: #f9a8d4; font-weight: 700; }
  .curl-flag { color: #93c5fd; }
  .curl-url  { color: #60a5fa; }
  .curl-str  { color: #86efac; }
  .copy-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 12px; border-radius: 7px;
    border: 1px solid #1f2937; background: #0d1117;
    color: #9ca3af; font-size: 12px; font-weight: 600;
    cursor: pointer; transition: border-color .15s, color .15s;
  }
  .copy-btn:hover { border-color: #374151; color: #e5e7eb; }
  .copy-btn.copied { color: #00e676; border-color: rgba(0,230,118,.35); }
  .curl-subtabs { display: flex; gap: 6px; margin-bottom: 10px; }
  .curl-subtab {
    padding: 4px 12px; border-radius: 6px;
    border: 1px solid #1f2937; background: transparent;
    color: #6b7280; font-size: 11px; font-weight: 600;
    cursor: pointer; transition: all .15s;
  }
  .curl-subtab.active { background: #111827; border-color: #374151; color: #e5e7eb; }

  /* ── Response panel ── */
  .res-panel {
    border: 1px solid #111827; border-radius: 14px;
    background: #060b14; overflow: hidden; margin-top: 14px;
  }
  .res-panel-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 11px 14px; border-bottom: 1px solid #111827; background: #080e1a;
  }
  .res-status-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 9px; border-radius: 6px; font-size: 11px; font-weight: 700;
  }
  .res-status-badge.ok   { background: rgba(0,230,118,.12); color: #00e676; border: 1px solid rgba(0,230,118,.25); }
  .res-status-badge.err  { background: rgba(239,68,68,.12);  color: #f87171; border: 1px solid rgba(239,68,68,.25); }
  .res-status-badge.idle { background: rgba(107,114,128,.1); color: #6b7280; border: 1px solid #1f2937; }

  /* ── Code Examples ── */
  .wh-code-panel {
    margin-top: 16px;
    border: 1px solid #111827; border-radius: 14px;
    background: #060b14; overflow: hidden;
  }
  .wh-code-panel-head {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 16px; border-bottom: 1px solid #111827; background: #080e1a;
  }
  .wh-code-panel-head h4 { margin: 0; font-size: 13px; font-weight: 700; color: #e5e7eb; }
  .wh-code-panel-head p  { margin: 0; font-size: 11px; color: #4b5563; }
  .wh-lang-tabs {
    display: flex; padding: 0 16px;
    border-bottom: 1px solid #111827; background: #080e1a;
    overflow-x: auto; scrollbar-width: none;
  }
  .wh-lang-tabs::-webkit-scrollbar { display: none; }
  .wh-lang-tab {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 9px 14px; font-size: 12px; font-weight: 600; color: #4b5563;
    cursor: pointer; border-bottom: 2px solid transparent;
    white-space: nowrap; transition: color .15s, border-color .15s; user-select: none;
  }
  .wh-lang-tab:hover:not(.active) { color: #9ca3af; }
  .wh-lang-tab.active { color: #e5e7eb; border-color: #00e676; }
  .wh-lang-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
  .wh-lang-body { display: none; }
  .wh-lang-body.active { display: block; }
  .wh-code-toolbar {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 16px 6px;
  }
  .wh-code-toolbar span { font-size: 11px; color: #374151; font-family: monospace; }
  .wh-copy-btn {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 11px; border-radius: 7px;
    border: 1px solid #1f2937; background: transparent;
    color: #6b7280; font-size: 11px; font-weight: 600;
    cursor: pointer; transition: all .15s;
  }
  .wh-copy-btn:hover  { border-color: #374151; color: #e5e7eb; }
  .wh-copy-btn.copied { color: #00e676; border-color: rgba(0,230,118,.35); }
  .wh-code-block {
    margin: 0 16px 16px;
    background: #020609; border: 1px solid #0d1117; border-radius: 10px;
    padding: 16px 18px;
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    font-size: 12px; line-height: 1.75;
    overflow-x: auto; white-space: pre;
    color: #d1d5db; max-height: 460px; overflow-y: auto;
  }
  /* token colours */
  .t-kw   { color: #c084fc; }
  .t-fn   { color: #60a5fa; }
  .t-str  { color: #86efac; }
  .t-num  { color: #fde68a; }
  .t-cmt  { color: #374151; font-style: italic; }
  .t-type { color: #f9a8d4; }
  .t-var  { color: #e5e7eb; }
  .t-op   { color: #94a3b8; }
  .t-prop { color: #93c5fd; }
  .t-anno { color: #fbbf24; }
</style>

<div class="wh-layout">

  <!-- ── Left: Form ── -->
  <div>
    <div class="card">
      <div class="hd">
        <div>
          <h3>Webhook Simulator</h3>
          <span>ยิงไปที่ <code>POST /api/webhook/evp</code> หรือ <code>POST /webhook/:paymentId</code></span>
        </div>
      </div>
      <div class="bd">
        <div class="muted" style="font-size:12px;margin-bottom:12px;padding:10px 12px;border-radius:10px;border:1px solid #1f2937;background:#080e1a;line-height:1.55;">
          <strong style="color:#e5e7eb;">ทดสอบจากเบราว์เซอร์:</strong> ไม่มี <code>webhook-signature</code> — ตั้ง <code>SKIP_WEBHOOK_VERIFY=true</code> ใน <code>.env</code> หรือยังไม่ใส่ <code>EVP_WEBHOOK_PUBLIC_KEY_B64</code><br />
          <strong style="color:#e5e7eb;">PowerShell:</strong> ใช้ <code>curl.exe</code> (ไม่ใช่ <code>curl</code> เพราะเป็น alias ของ Invoke-WebRequest) และส่ง body จากไฟล์ด้วย <code>--data-binary &quot;@body.json&quot;</code>
        </div>
        <div class="grid">
          <% if (payments && payments.length) { %>
          <div style="grid-column: 1 / -1;">
            <label>เลือก Payment จากรายการล่าสุด</label>
            <input id="paymentPick" list="webhookPaymentList" placeholder="พิมพ์ค้นหาแล้วเลือก (จะใส่ EVP Payment ID ใน payload)" autocomplete="off" />
            <datalist id="webhookPaymentList"></datalist>
          </div>
          <% } %>
          <div style="grid-column: 1 / -1;">
            <label>Webhook JSON Payload</label>
            <textarea id="payload" style="min-height:220px; font-family: 'JetBrains Mono','Fira Code',monospace; font-size:12px;"></textarea>
            <div class="muted" style="font-size:12px;margin-top:6px;">
              ต้องมี <code>data.payment_id</code> / <code>payment_id</code> หรือคู่ reference ตามที่ API รองรับ — ดู <a href="https://docs.evp-pay.com/introduction" target="_blank" rel="noopener" style="color:#93c5fd;">เอกสาร EVP</a>
            </div>
          </div>
          <div>
            <label>Optional: Payment_ID ใน URL <span class="muted" style="font-weight:400;">(<code>POST /webhook/:id</code>)</span></label>
            <input id="paymentIdInPath" placeholder="89224ac9-..." />
          </div>
          <div>
            <label>&nbsp;</label>
            <button class="btn" type="button" id="sendBtn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              Send Webhook
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Response panel -->
    <div class="res-panel">
      <div class="res-panel-head">
        <span style="font-size:12px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:.4px;">Response</span>
        <span id="resStatusBadge" class="res-status-badge idle">—</span>
      </div>
      <div style="padding:12px 14px;">
        <pre id="result" style="margin:0;font-family:monospace;font-size:12px;line-height:1.6;color:#9ca3af;max-height:280px;overflow:auto;background:#020609;border:1px solid #0d1117;border-radius:8px;padding:12px;">ยังไม่มี</pre>
      </div>
    </div>
  </div>

  <!-- ── Right: Request Inspector ── -->
  <div class="req-panel" id="reqPanel">

    <div class="req-panel-head">
      <span>Request Inspector</span>
      <div style="display:flex;gap:6px;">
        <% if (merchant) { %>
          <span style="font-size:11px;padding:3px 9px;border-radius:6px;background:rgba(0,230,118,.1);color:#00e676;border:1px solid rgba(0,230,118,.2);font-weight:700;"><%= merchant.Terminal_ID %></span>
        <% } else { %>
          <span style="font-size:11px;padding:3px 9px;border-radius:6px;background:rgba(239,68,68,.1);color:#f87171;border:1px solid rgba(239,68,68,.2);font-weight:700;">No Active Merchant</span>
        <% } %>
      </div>
    </div>

    <div class="req-url-bar">
      <span class="req-method">POST</span>
      <span class="req-url" id="reqUrlDisplay">/api/webhook/evp</span>
    </div>

    <div class="req-tabs">
      <div class="req-tab active" data-tab="headers">Headers</div>
      <div class="req-tab" data-tab="body">Body</div>
      <div class="req-tab" data-tab="curl">cURL</div>
    </div>

    <!-- Headers -->
    <div class="req-body active" id="tab-headers">
      <table class="req-headers">
        <tr><td>Content-Type</td><td>application/json</td></tr>
        <tr><td>webhook-id</td><td style="color:#6b7280;">(generated by EVP)</td></tr>
        <tr><td>webhook-timestamp</td><td style="color:#6b7280;">(unix timestamp, set by EVP)</td></tr>
        <tr><td>webhook-signature</td><td style="color:#6b7280;">omit → set <code>SKIP_WEBHOOK_VERIFY=true</code></td></tr>
      </table>
    </div>

    <!-- Body -->
    <div class="req-body" id="tab-body">
      <div class="req-json" id="bodyPreview"></div>
    </div>

    <!-- cURL -->
    <div class="req-body" id="tab-curl">
      <div class="curl-subtabs">
        <button class="curl-subtab active" data-curl="general">General endpoint</button>
        <button class="curl-subtab" data-curl="perpayment">Per-payment URL</button>
      </div>
      <div id="curlGeneral" class="req-curl"></div>
      <div id="curlPerPayment" class="req-curl" style="display:none;"></div>
      <div style="margin-top:10px;display:flex;gap:8px;">
        <button class="copy-btn" id="btnCopyCurl">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          Copy cURL
        </button>
        <button class="copy-btn" id="btnCopyJson">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
          Copy JSON
        </button>
      </div>
    </div>

  </div><!-- /req-panel -->
</div><!-- /wh-layout -->

<script>
(function () {
  var payloadEl        = document.getElementById('payload');
  var pidInput         = document.getElementById('paymentIdInPath');
  var sendBtn          = document.getElementById('sendBtn');
  var resultEl         = document.getElementById('result');
  var resStatusBadge   = document.getElementById('resStatusBadge');
  var bodyPreview      = document.getElementById('bodyPreview');
  var curlGeneralEl    = document.getElementById('curlGeneral');
  var curlPerPayEl     = document.getElementById('curlPerPayment');
  var reqUrlDisplay    = document.getElementById('reqUrlDisplay');

  var activeCurlMode = 'general';

  var payments = <%- JSON.stringify(payments || []) %>;
  var paymentPick = document.getElementById('paymentPick');
  var webhookPaymentList = document.getElementById('webhookPaymentList');

  function fmtDateWh(v) {
    if (!v) return '';
    try {
      var d = new Date(v);
      if (isNaN(d.getTime())) return String(v);
      return d.toISOString();
    } catch (e) {
      return String(v);
    }
  }

  function buildWhOption(p) {
    var pid = p.Res_Payment_ID || '';
    var label = [
      pid,
      p.Res_Status ? '(' + p.Res_Status + ')' : '',
      p.Ref_TRN ? 'TRN:' + p.Ref_TRN : '',
      p.Ref_Order_ID ? 'Order:' + p.Ref_Order_ID : '',
      p.CreatedAtUtc ? fmtDateWh(p.CreatedAtUtc) : ''
    ].filter(Boolean).join('  •  ');
    return { pid: pid, label: label };
  }

  if (webhookPaymentList && payments.length) {
    webhookPaymentList.innerHTML = payments.map(function (p) {
      var o = buildWhOption(p);
      return '<option value="' + String(o.label).replace(/"/g, '&quot;') + '"></option>';
    }).join('');
  }

  /* ── sample payload ── */
  var sample = {
    type: 'payment.completed',
    data: {
      payment_id: '<%= W_SAMPLE_PID || 'PUT-REAL-PAYMENT_ID-HERE' %>',
      status: 'completed',
      terminal_id: '<%= W_TERMINAL %>',
      transaction_type: 'SALE',
      amount: 10000,
      curr_code: 764,
      payment_method: 'Card',
      payment_network: 'Visa',
      masked_pan: '441770******7408',
      reference: {
        order_id: 'ORD-TEST-001',
        customer_id: 'CUST-003',
        transaction_ref: 'TXN-TEST-003'
      },
      created_at: new Date().toISOString(),
      paid_at: new Date().toISOString()
    }
  };
  payloadEl.value = JSON.stringify(sample, null, 2);

  /* ── helpers ── */
  function esc(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function pid()        { return pidInput ? pidInput.value.trim() : ''; }
  function generalUrl() { return '/api/webhook/evp'; }
  function perPayUrl()  { var p = pid(); return p ? ('/webhook/' + encodeURIComponent(p)) : '/webhook/{payment_id}'; }
  function currentUrl() { return activeCurlMode === 'perpayment' ? perPayUrl() : generalUrl(); }

  function colorJson(obj) {
    var s = JSON.stringify(obj, null, 2);
    return s.replace(/("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(?:\.\d*)?(?:[eE][+\-]?\d+)?)/g, function (m) {
      if (/^"/.test(m)) {
        if (/:$/.test(m)) return '<span class="json-key">' + esc(m) + '</span>';
        return '<span class="json-str">' + esc(m) + '</span>';
      }
      if (/true|false|null/.test(m)) return '<span class="json-null">' + m + '</span>';
      return '<span class="json-num">' + m + '</span>';
    });
  }

  function buildCurlHtml(url) {
    var full = esc(window.location.origin + url);
    return '<span style="color:#6b7280;font-size:11px;display:block;margin-bottom:8px;">บันทึก JSON จากแท็บ Body เป็นไฟล์ <code style="color:#86efac;">body.json</code> ในโฟลเดอร์เดียวกัน แล้วรัน:</span>'
      + '<span class="curl-cmd">curl.exe</span> <span class="curl-flag">-X POST</span> <span class="curl-url">' + full + '</span> \\\n'
      + '  <span class="curl-flag">-H</span> <span class="curl-str">"Content-Type: application/json"</span> \\\n'
      + '  <span class="curl-flag">--data-binary</span> <span class="curl-str">"@body.json"</span>';
  }

  function update() {
    var raw = payloadEl.value.trim() || '{}';
    var parsed = null;
    try { parsed = JSON.parse(payloadEl.value); } catch (e) {}

    /* url bar */
    if (reqUrlDisplay) reqUrlDisplay.textContent = currentUrl();

    /* body preview */
    if (bodyPreview) {
      bodyPreview.innerHTML = parsed
        ? colorJson(parsed)
        : '<span style="color:#f87171;">⚠ Invalid JSON</span>';
    }

    /* curl panels (file-based — ใช้ได้บน PowerShell / cmd) */
    if (curlGeneralEl) curlGeneralEl.innerHTML = buildCurlHtml(generalUrl());
    if (curlPerPayEl) curlPerPayEl.innerHTML = buildCurlHtml(perPayUrl());
  }

  function applyPaymentIdToPayload(pidVal) {
    if (!pidVal || !payloadEl) return;
    try {
      var j = JSON.parse(payloadEl.value);
      if (j && typeof j === 'object') {
        if (j.data && typeof j.data === 'object') j.data.payment_id = pidVal;
        else j.payment_id = pidVal;
        payloadEl.value = JSON.stringify(j, null, 2);
        update();
      }
    } catch (e) { /* ignore */ }
  }

  if (paymentPick) {
    paymentPick.addEventListener('change', function () {
      var v = paymentPick.value.trim();
      if (!v) return;
      var id = v.split('  •  ')[0].trim();
      if (id) applyPaymentIdToPayload(id);
    });
  }

  /* live updates */
  payloadEl.addEventListener('input', update);
  if (pidInput) pidInput.addEventListener('input', update);

  /* tab switching */
  document.querySelectorAll('.req-tab').forEach(function (tab) {
    tab.addEventListener('click', function () {
      document.querySelectorAll('.req-tab').forEach(function (t) { t.classList.remove('active'); });
      document.querySelectorAll('.req-body').forEach(function (b) { b.classList.remove('active'); });
      tab.classList.add('active');
      var target = document.getElementById('tab-' + tab.getAttribute('data-tab'));
      if (target) target.classList.add('active');
    });
  });

  /* curl subtabs */
  document.querySelectorAll('.curl-subtab').forEach(function (st) {
    st.addEventListener('click', function () {
      document.querySelectorAll('.curl-subtab').forEach(function (t) { t.classList.remove('active'); });
      st.classList.add('active');
      activeCurlMode = st.getAttribute('data-curl');
      if (curlGeneralEl) curlGeneralEl.style.display = activeCurlMode === 'general'    ? '' : 'none';
      if (curlPerPayEl)  curlPerPayEl.style.display  = activeCurlMode === 'perpayment' ? '' : 'none';
      update();
    });
  });

  /* copy helper */
  function copyText(text, btn) {
    navigator.clipboard.writeText(text).then(function () {
      btn.classList.add('copied');
      var orig = btn.innerHTML;
      btn.innerHTML = btn.innerHTML.replace(/Copy.*/i, 'Copied!');
      setTimeout(function () { btn.classList.remove('copied'); btn.innerHTML = orig; }, 1800);
    });
  }

  var btnCopyCurl = document.getElementById('btnCopyCurl');
  var btnCopyJson = document.getElementById('btnCopyJson');

  if (btnCopyCurl) {
    btnCopyCurl.addEventListener('click', function () {
      var url = window.location.origin + currentUrl();
      var raw = '# Save the JSON from the Body tab as body.json in the same folder, then:\r\n'
        + 'curl.exe -X POST "' + url + '" \\\r\n'
        + '  -H "Content-Type: application/json" \\\r\n'
        + '  --data-binary "@body.json"';
      copyText(raw, btnCopyCurl);
    });
  }
  if (btnCopyJson) {
    btnCopyJson.addEventListener('click', function () {
      copyText(payloadEl.value.trim(), btnCopyJson);
    });
  }

  /* ── Send Webhook ── */
  sendBtn.addEventListener('click', async function () {
    var json;
    try { json = JSON.parse(payloadEl.value); }
    catch (e) { resultEl.textContent = 'Invalid JSON: ' + e.message; return; }

    var url = pid() ? ('/webhook/' + encodeURIComponent(pid())) : '/api/webhook/evp';
    sendBtn.disabled = true;
    sendBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> Sending…';
    resStatusBadge.className = 'res-status-badge idle';
    resStatusBadge.textContent = 'Loading…';
    resultEl.textContent = '…';

    try {
      var res = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(json)
      });
      var text = await res.text();
      var parsed = null;
      try { parsed = JSON.parse(text); } catch {}
      var hint = '';
      if (res.status === 401 && parsed && parsed.message && String(parsed.message).indexOf('signature') >= 0) {
        hint = '\n\n— ตั้ง SKIP_WEBHOOK_VERIFY=true หรืออย่าใส่ EVP_WEBHOOK_PUBLIC_KEY_B64 เมื่อทดสอบจากเบราว์เซอร์';
      }
      resultEl.textContent = 'POST ' + url + '\nHTTP ' + res.status + '\n\n'
        + (parsed ? JSON.stringify(parsed, null, 2) : text) + hint;
      resStatusBadge.className = 'res-status-badge ' + (res.ok ? 'ok' : 'err');
      resStatusBadge.textContent = res.status + ' ' + (res.ok ? 'OK' : 'Error');
    } catch (e) {
      resultEl.textContent = 'Error: ' + e.message;
      resStatusBadge.className = 'res-status-badge err';
      resStatusBadge.textContent = 'Network Error';
    } finally {
      sendBtn.disabled = false;
      sendBtn.innerHTML = '<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg> Send Webhook';
    }
  });

  /* initial render */
  update();
})();
</script>

