<script>
(function () {
  /* ── shared DOM refs ── */
  var payloadEl = document.getElementById('payload');
  var pidInputEl = document.getElementById('paymentIdInPath');

  function pid()    { return pidInputEl ? pidInputEl.value.trim() : ''; }
  function whBase() {
    if (typeof window !== 'undefined' && window.location && window.location.origin) {
      return window.location.origin;
    }
    return '<%= W_APP_URL %>';
  }
  function whUrl()  {
    var p = pid();
    var base = whBase();
    return p ? (base + '/webhook/' + encodeURIComponent(p)) : (base + '/api/webhook/evp');
  }
  function rawBody() { return payloadEl ? payloadEl.value.trim() : '{}'; }

  /* ── token helpers ── */
  function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
  function kw(s)  { return '<span class="t-kw">'   + esc(s) + '</span>'; }
  function fn(s)  { return '<span class="t-fn">'   + esc(s) + '</span>'; }
  function st(s)  { return '<span class="t-str">'  + esc(s) + '</span>'; }
  function num(s) { return '<span class="t-num">'  + esc(s) + '</span>'; }
  function cmt(s) { return '<span class="t-cmt">'  + esc(s) + '</span>'; }
  function ty(s)  { return '<span class="t-type">' + esc(s) + '</span>'; }
  function vr(s)  { return '<span class="t-var">'  + esc(s) + '</span>'; }
  function op(s)  { return '<span class="t-op">'   + esc(s) + '</span>'; }
  function pr(s)  { return '<span class="t-prop">' + esc(s) + '</span>'; }

  /* ── generators (return innerHTML) ── */
  function genNodejs() {
    var url = whUrl(), body = rawBody();
    return kw('const') + ' ' + vr('axios') + ' ' + op('=') + ' ' + fn('require') + '(' + st('"axios"') + ');\n'
      + '\n'
      + cmt('// Webhook Simulator — send payload to EVP gateway') + '\n'
      + kw('const') + ' ' + vr('payload') + ' ' + op('=') + ' ' + esc(body) + ';\n'
      + '\n'
      + kw('async function') + ' ' + fn('sendWebhook') + '() {\n'
      + '  ' + kw('try') + ' {\n'
      + '    ' + kw('const') + ' { ' + pr('data') + ' } ' + op('=') + ' ' + kw('await') + ' ' + vr('axios') + '.' + fn('post') + '(\n'
      + '      ' + st('"' + url + '"') + ',\n'
      + '      ' + vr('payload') + ',\n'
      + '      { ' + pr('headers') + ': { ' + st('"Content-Type"') + ': ' + st('"application/json"') + ' } }\n'
      + '    );\n'
      + '    ' + vr('console') + '.' + fn('log') + '(' + st('"✅ Response:"') + ', ' + vr('data') + ');\n'
      + '  } ' + kw('catch') + ' (' + vr('err') + ') {\n'
      + '    ' + vr('console') + '.' + fn('error') + '(' + st('"❌ Error:"') + ', ' + vr('err') + '.' + pr('message') + ');\n'
      + '  }\n'
      + '}\n\n'
      + fn('sendWebhook') + '();';
  }
  function rawNodejs() {
    return 'const axios = require("axios");\n\n// Webhook Simulator — send payload to EVP gateway\nconst payload = '
      + rawBody() + ';\n\nasync function sendWebhook() {\n  try {\n    const { data } = await axios.post(\n      "'
      + whUrl() + '",\n      payload,\n      { headers: { "Content-Type": "application/json" } }\n    );\n    console.log("✅ Response:", data);\n  } catch (err) {\n    console.error("❌ Error:", err.message);\n  }\n}\n\nsendWebhook();';
  }

  function genJs() {
    var url = whUrl(), body = rawBody();
    return cmt('// Webhook Simulator — send payload to EVP gateway') + '\n'
      + kw('const') + ' ' + vr('payload') + ' ' + op('=') + ' ' + esc(body) + ';\n\n'
      + fn('fetch') + '(' + st('"' + url + '"') + ', {\n'
      + '  ' + pr('method') + ': ' + st('"POST"') + ',\n'
      + '  ' + pr('headers') + ': { ' + st('"Content-Type"') + ': ' + st('"application/json"') + ' },\n'
      + '  ' + pr('body') + ': ' + ty('JSON') + '.' + fn('stringify') + '(' + vr('payload') + ')\n'
      + '})\n'
      + '.' + fn('then') + '(' + vr('res') + ' => ' + vr('res') + '.' + fn('json') + '())\n'
      + '.' + fn('then') + '(' + vr('data') + ' => ' + vr('console') + '.' + fn('log') + '(' + st('"✅ Response:"') + ', ' + vr('data') + '))\n'
      + '.' + fn('catch') + '(' + vr('err') + ' => ' + vr('console') + '.' + fn('error') + '(' + st('"❌ Error:"') + ', ' + vr('err') + '));';
  }
  function rawJs() {
    return '// Webhook Simulator — send payload to EVP gateway\nconst payload = ' + rawBody()
      + ';\n\nfetch("' + whUrl() + '", {\n  method: "POST",\n  headers: { "Content-Type": "application/json" },\n  body: JSON.stringify(payload)\n})\n.then(res => res.json())\n.then(data => console.log("✅ Response:", data))\n.catch(err => console.error("❌ Error:", err));';
  }

  function genPython() {
    var url = whUrl(), body = rawBody();
    return kw('import') + ' ' + vr('requests') + '\n\n'
      + cmt('# Webhook Simulator — send payload to EVP gateway') + '\n'
      + vr('payload') + ' ' + op('=') + ' ' + esc(body) + '\n\n'
      + vr('response') + ' ' + op('=') + ' ' + vr('requests') + '.' + fn('post') + '(\n'
      + '    ' + st('"' + url + '"') + ',\n'
      + '    ' + pr('json') + op('=') + vr('payload') + '\n'
      + ')\n\n'
      + kw('print') + '(' + st('"✅ Status:"') + ', ' + vr('response') + '.' + pr('status_code') + ')\n'
      + kw('print') + '(' + st('"📦 Response:"') + ', ' + vr('response') + '.' + fn('json') + '())';
  }
  function rawPython() {
    return 'import requests\n\n# Webhook Simulator — send payload to EVP gateway\npayload = '
      + rawBody() + '\n\nresponse = requests.post(\n    "' + whUrl() + '",\n    json=payload\n)\n\nprint("✅ Status:", response.status_code)\nprint("📦 Response:", response.json())';
  }

  function genCsharp() {
    var url = whUrl(), body = rawBody();
    var escapedBody = body.replace(/\\/g, '\\\\').replace(/"/g, '\\"');
    return kw('using') + ' ' + ty('System') + '.' + ty('Net') + '.' + ty('Http') + ';\n'
      + kw('using') + ' ' + ty('System') + '.' + ty('Text') + ';\n'
      + kw('using') + ' ' + ty('System') + '.' + ty('Text') + '.' + ty('Json') + ';\n\n'
      + cmt('// Webhook Simulator — send payload to EVP gateway') + '\n'
      + kw('var') + ' ' + vr('jsonBody') + ' ' + op('=') + ' ' + st('"' + escapedBody + '"') + ';\n'
      + kw('var') + ' ' + vr('content') + ' ' + op('=') + ' ' + kw('new') + ' ' + ty('StringContent') + '(\n'
      + '    ' + vr('jsonBody') + ', ' + ty('Encoding') + '.' + pr('UTF8') + ', ' + st('"application/json"') + '\n'
      + ');\n\n'
      + kw('using var') + ' ' + vr('client') + ' ' + op('=') + ' ' + kw('new') + ' ' + ty('HttpClient') + '();\n'
      + kw('var') + ' ' + vr('response') + ' ' + op('=') + ' ' + kw('await') + ' ' + vr('client') + '.' + fn('PostAsync') + '(\n'
      + '    ' + st('"' + url + '"') + ', ' + vr('content') + '\n'
      + ');\n\n'
      + kw('var') + ' ' + vr('result') + ' ' + op('=') + ' ' + kw('await') + ' ' + vr('response') + '.' + pr('Content') + '.' + fn('ReadAsStringAsync') + '();\n'
      + ty('Console') + '.' + fn('WriteLine') + '(' + st('"✅ Status: "') + ' + ' + vr('response') + '.' + pr('StatusCode') + ');\n'
      + ty('Console') + '.' + fn('WriteLine') + '(' + st('"📦 Response: "') + ' + ' + vr('result') + ');';
  }
  function rawCsharp() {
    var url = whUrl(), body = rawBody();
    var escapedBody = body.replace(/\\/g, '\\\\').replace(/"/g, '\\"');
    return 'using System.Net.Http;\nusing System.Text;\nusing System.Text.Json;\n\n// Webhook Simulator — send payload to EVP gateway\nvar jsonBody = "' + escapedBody + '";\nvar content = new StringContent(\n    jsonBody, Encoding.UTF8, "application/json"\n);\n\nusing var client = new HttpClient();\nvar response = await client.PostAsync(\n    "' + url + '", content\n);\n\nvar result = await response.Content.ReadAsStringAsync();\nConsole.WriteLine("✅ Status: " + response.StatusCode);\nConsole.WriteLine("📦 Response: " + result);';
  }

  function genCpp() {
    var url = whUrl(), body = rawBody();
    return kw('#include') + ' ' + st('&lt;curl/curl.h&gt;') + '\n'
      + kw('#include') + ' ' + st('&lt;iostream&gt;') + '\n'
      + kw('#include') + ' ' + st('&lt;string&gt;') + '\n\n'
      + cmt('// Webhook Simulator — requires libcurl') + '\n'
      + cmt('// Install: brew install curl  /  apt install libcurl4-openssl-dev') + '\n\n'
      + kw('int') + ' ' + fn('main') + '() {\n'
      + '    ' + ty('CURL') + op('*') + ' ' + vr('curl') + ' ' + op('=') + ' ' + fn('curl_easy_init') + '();\n'
      + '    ' + kw('if') + ' (!' + vr('curl') + ') ' + kw('return') + ' ' + num('1') + ';\n\n'
      + '    ' + ty('std') + '::' + ty('string') + ' ' + vr('url') + ' ' + op('=') + ' ' + st('"' + url + '"') + ';\n'
      + '    ' + ty('std') + '::' + ty('string') + ' ' + vr('payload') + ' ' + op('=') + ' ' + st('R"(' + esc(body) + ')"') + ';\n\n'
      + '    ' + kw('struct') + ' ' + ty('curl_slist') + op('*') + ' ' + vr('headers') + ' ' + op('=') + ' ' + kw('nullptr') + ';\n'
      + '    ' + vr('headers') + ' ' + op('=') + ' ' + fn('curl_slist_append') + '(' + vr('headers') + ', ' + st('"Content-Type: application/json"') + ');\n\n'
      + '    ' + fn('curl_easy_setopt') + '(' + vr('curl') + ', ' + ty('CURLOPT_URL') + ',        ' + vr('url') + '.' + fn('c_str') + '());\n'
      + '    ' + fn('curl_easy_setopt') + '(' + vr('curl') + ', ' + ty('CURLOPT_POST') + ',       ' + num('1L') + ');\n'
      + '    ' + fn('curl_easy_setopt') + '(' + vr('curl') + ', ' + ty('CURLOPT_POSTFIELDS') + ',  ' + vr('payload') + '.' + fn('c_str') + '());\n'
      + '    ' + fn('curl_easy_setopt') + '(' + vr('curl') + ', ' + ty('CURLOPT_HTTPHEADER') + ',  ' + vr('headers') + ');\n\n'
      + '    ' + ty('CURLcode') + ' ' + vr('res') + ' ' + op('=') + ' ' + fn('curl_easy_perform') + '(' + vr('curl') + ');\n'
      + '    ' + kw('if') + ' (' + vr('res') + ' ' + op('!=') + ' ' + ty('CURLE_OK') + ')\n'
      + '        ' + ty('std') + '::' + vr('cerr') + ' ' + op('&lt;&lt;') + ' ' + st('"❌ "') + ' ' + op('&lt;&lt;') + ' ' + fn('curl_easy_strerror') + '(' + vr('res') + ') ' + op('&lt;&lt;') + ' ' + ty('std') + '::' + vr('endl') + ';\n\n'
      + '    ' + fn('curl_slist_free_all') + '(' + vr('headers') + ');\n'
      + '    ' + fn('curl_easy_cleanup') + '(' + vr('curl') + ');\n'
      + '    ' + kw('return') + ' ' + num('0') + ';\n'
      + '}';
  }
  function rawCpp() {
    var url = whUrl(), body = rawBody();
    return '#include <curl/curl.h>\n#include <iostream>\n#include <string>\n\n// Webhook Simulator — requires libcurl\n\nint main() {\n    CURL* curl = curl_easy_init();\n    if (!curl) return 1;\n\n    std::string url = "' + url + '";\n    std::string payload = R"(' + body + ')";\n\n    struct curl_slist* headers = nullptr;\n    headers = curl_slist_append(headers, "Content-Type: application/json");\n\n    curl_easy_setopt(curl, CURLOPT_URL,       url.c_str());\n    curl_easy_setopt(curl, CURLOPT_POST,      1L);\n    curl_easy_setopt(curl, CURLOPT_POSTFIELDS, payload.c_str());\n    curl_easy_setopt(curl, CURLOPT_HTTPHEADER, headers);\n\n    CURLcode res = curl_easy_perform(curl);\n    if (res != CURLE_OK)\n        std::cerr << "❌ " << curl_easy_strerror(res) << std::endl;\n\n    curl_slist_free_all(headers);\n    curl_easy_cleanup(curl);\n    return 0;\n}';
  }

  function genPhp() {
    var url = whUrl(), body = rawBody();
    var escapedBody = body.replace(/'/g, "\\'");
    return kw('&lt;?php') + '\n'
      + cmt('// Webhook Simulator — send payload to EVP gateway') + '\n\n'
      + vr('$payload') + ' ' + op('=') + ' ' + fn('json_decode') + '(' + st("'" + escapedBody + "'") + ', ' + kw('true') + ');\n\n'
      + vr('$ch') + ' ' + op('=') + ' ' + fn('curl_init') + '(' + st("'" + url + "'") + ');\n'
      + fn('curl_setopt') + '(' + vr('$ch') + ', ' + ty('CURLOPT_POST') + ',            ' + kw('true') + ');\n'
      + fn('curl_setopt') + '(' + vr('$ch') + ', ' + ty('CURLOPT_POSTFIELDS') + ',      ' + fn('json_encode') + '(' + vr('$payload') + '));\n'
      + fn('curl_setopt') + '(' + vr('$ch') + ', ' + ty('CURLOPT_HTTPHEADER') + ',      [' + st("'Content-Type: application/json'") + ']);\n'
      + fn('curl_setopt') + '(' + vr('$ch') + ', ' + ty('CURLOPT_RETURNTRANSFER') + ', ' + kw('true') + ');\n\n'
      + vr('$result') + ' ' + op('=') + ' ' + fn('curl_exec') + '(' + vr('$ch') + ');\n'
      + vr('$status') + ' ' + op('=') + ' ' + fn('curl_getinfo') + '(' + vr('$ch') + ', ' + ty('CURLINFO_HTTP_CODE') + ');\n'
      + fn('curl_close') + '(' + vr('$ch') + ');\n\n'
      + kw('echo') + ' ' + st('"✅ Status: "') + ' . ' + vr('$status') + ' . ' + st('"\\n"') + ';\n'
      + kw('echo') + ' ' + st('"📦 Response: "') + ' . ' + vr('$result') + ' . ' + st('"\\n"') + ';';
  }
  function rawPhp() {
    var url = whUrl(), body = rawBody();
    return "<?php\n// Webhook Simulator — send payload to EVP gateway\n\n$payload = json_decode('" + body.replace(/'/g, "\\'") + "', true);\n\n$ch = curl_init('" + url + "');\ncurl_setopt($ch, CURLOPT_POST,            true);\ncurl_setopt($ch, CURLOPT_POSTFIELDS,      json_encode($payload));\ncurl_setopt($ch, CURLOPT_HTTPHEADER,      ['Content-Type: application/json']);\ncurl_setopt($ch, CURLOPT_RETURNTRANSFER, true);\n\n$result = curl_exec($ch);\n$status = curl_getinfo($ch, CURLINFO_HTTP_CODE);\ncurl_close($ch);\n\necho \"✅ Status: \" . $status . \"\\n\";\necho \"📦 Response: \" . $result . \"\\n\";";
  }

  function genHtml() {
    var url = whUrl(), body = rawBody();
    return kw('&lt;!DOCTYPE html&gt;') + '\n'
      + kw('&lt;html') + ' ' + pr('lang') + op('=') + st('"en"') + kw('&gt;') + '\n'
      + kw('&lt;head&gt;') + '\n'
      + '  ' + kw('&lt;meta') + ' ' + pr('charset') + op('=') + st('"UTF-8"') + kw('&gt;') + '\n'
      + '  ' + kw('&lt;title&gt;') + 'Webhook Simulator' + kw('&lt;/title&gt;') + '\n'
      + kw('&lt;/head&gt;') + '\n'
      + kw('&lt;body&gt;') + '\n'
      + '  ' + kw('&lt;button') + ' ' + pr('onclick') + op('=') + st('"sendWebhook()"') + kw('&gt;') + 'Send Webhook' + kw('&lt;/button&gt;') + '\n'
      + '  ' + kw('&lt;pre') + ' ' + pr('id') + op('=') + st('"output"') + kw('&gt;&lt;/pre&gt;') + '\n'
      + kw('&lt;script&gt;') + '\n'
      + '  ' + kw('async function') + ' ' + fn('sendWebhook') + '() {\n'
      + '    ' + kw('const') + ' ' + vr('payload') + ' ' + op('=') + ' ' + esc(body) + ';\n'
      + '    ' + kw('const') + ' ' + vr('res') + ' ' + op('=') + ' ' + kw('await') + ' ' + fn('fetch') + '(' + st('"' + url + '"') + ', {\n'
      + '      ' + pr('method') + ': ' + st('"POST"') + ',\n'
      + '      ' + pr('headers') + ': { ' + st('"Content-Type"') + ': ' + st('"application/json"') + ' },\n'
      + '      ' + pr('body') + ': ' + ty('JSON') + '.' + fn('stringify') + '(' + vr('payload') + ')\n'
      + '    });\n'
      + '    ' + kw('const') + ' ' + vr('data') + ' ' + op('=') + ' ' + kw('await') + ' ' + vr('res') + '.' + fn('json') + '();\n'
      + '    ' + vr('document') + '.' + fn('getElementById') + '(' + st('"output"') + ').' + pr('textContent') + ' ' + op('=') + ' ' + ty('JSON') + '.' + fn('stringify') + '(' + vr('data') + ', ' + kw('null') + ', ' + num('2') + ');\n'
      + '  }\n'
      + kw('&lt;/script&gt;') + '\n'
      + kw('&lt;/body&gt;') + '\n'
      + kw('&lt;/html&gt;');
  }
  function rawHtml() {
    var url = whUrl(), body = rawBody();
    return '<!DOCTYPE html>\n<html lang="en">\n<head>\n  <meta charset="UTF-8">\n  <title>Webhook Simulator</title>\n</head>\n<body>\n  <button onclick="sendWebhook()">Send Webhook</button>\n  <pre id="output"></pre>\n<script>\n  async function sendWebhook() {\n    const payload = ' + body + ';\n    const res = await fetch("' + url + '", {\n      method: "POST",\n      headers: { "Content-Type": "application/json" },\n      body: JSON.stringify(payload)\n    });\n    const data = await res.json();\n    document.getElementById("output").textContent = JSON.stringify(data, null, 2);\n  }\n<\/script>\n</body>\n</html>';
  }

  var generators = { nodejs: genNodejs, js: genJs, python: genPython, csharp: genCsharp, cpp: genCpp, php: genPhp, html: genHtml };
  var rawGens    = { nodejs: rawNodejs, js: rawJs, python: rawPython, csharp: rawCsharp, cpp: rawCpp, php: rawPhp, html: rawHtml };

  function updateExamples() {
    Object.keys(generators).forEach(function (lang) {
      var el = document.getElementById('wh-code-' + lang);
      if (el) el.innerHTML = generators[lang]();
    });
  }

  /* lang tab switching */
  document.querySelectorAll('.wh-lang-tab').forEach(function (tab) {
    tab.addEventListener('click', function () {
      document.querySelectorAll('.wh-lang-tab').forEach(function (t) { t.classList.remove('active'); });
      document.querySelectorAll('.wh-lang-body').forEach(function (b) { b.classList.remove('active'); });
      tab.classList.add('active');
      var target = document.getElementById('wh-lang-' + tab.getAttribute('data-lang'));
      if (target) target.classList.add('active');
    });
  });

  /* copy buttons */
  document.querySelectorAll('.wh-copy-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var lang = btn.getAttribute('data-copy');
      if (!rawGens[lang]) return;
      navigator.clipboard.writeText(rawGens[lang]()).then(function () {
        btn.classList.add('copied');
        var orig = btn.innerHTML;
        btn.innerHTML = btn.innerHTML.replace(/Copy/i, 'Copied!');
        setTimeout(function () { btn.classList.remove('copied'); btn.innerHTML = orig; }, 1800);
      });
    });
  });

  /* live update on payload or pid change */
  if (payloadEl)  payloadEl.addEventListener('input', updateExamples);
  if (pidInputEl) pidInputEl.addEventListener('input', updateExamples);

  updateExamples();
})();
</script>

