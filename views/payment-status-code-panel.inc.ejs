<style>
  .code-panel {
    margin-top: 16px;
    border: 1px solid #111827;
    border-radius: 14px;
    background: #060b14;
    overflow: hidden;
  }
  .code-panel-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-bottom: 1px solid #111827;
    background: #080e1a;
  }
  .code-panel-head h4 {
    margin: 0;
    font-size: 13px;
    font-weight: 700;
    color: #e5e7eb;
  }
  .code-panel-head p { margin: 0; font-size: 11px; color: #4b5563; }

  .lang-tabs {
    display: flex;
    gap: 0;
    padding: 0 16px;
    border-bottom: 1px solid #111827;
    background: #080e1a;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .lang-tabs::-webkit-scrollbar { display: none; }
  .lang-tab {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 14px;
    font-size: 12px;
    font-weight: 600;
    color: #4b5563;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color .15s, border-color .15s;
    user-select: none;
  }
  .lang-tab:hover:not(.active) { color: #9ca3af; }
  .lang-tab.active { color: #e5e7eb; border-color: #00e676; }
  .lang-tab .lang-dot {
    width: 8px; height: 8px; border-radius: 50%;
    flex-shrink: 0;
  }

  .lang-body { display: none; }
  .lang-body.active { display: block; }

  .code-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px 6px;
  }
  .code-toolbar span {
    font-size: 11px;
    color: #374151;
    font-family: monospace;
  }
  .code-copy-btn {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 11px;
    border-radius: 7px;
    border: 1px solid #1f2937;
    background: transparent;
    color: #6b7280;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    transition: all .15s;
  }
  .code-copy-btn:hover { border-color: #374151; color: #e5e7eb; }
  .code-copy-btn.copied { color: #00e676; border-color: rgba(0,230,118,.35); }

  .code-block {
    margin: 0 16px 16px;
    background: #020609;
    border: 1px solid #0d1117;
    border-radius: 10px;
    padding: 16px 18px;
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
    font-size: 12px;
    line-height: 1.75;
    overflow-x: auto;
    white-space: pre;
    color: #d1d5db;
    max-height: 460px;
    overflow-y: auto;
  }

  .curl-subtabs {
    display: flex; gap: 6px; margin-bottom: 0;
  }
  .curl-subtab {
    padding: 5px 14px;
    border-radius: 999px;
    border: 1px solid transparent;
    background: transparent;
    color: #6b7280;
    font-size: 11px;
    font-weight: 600;
    cursor: pointer;
    transition: all .15s;
  }
  .curl-subtab.active {
    background: rgba(17, 24, 39, 0.9);
    border-color: #e5e7eb;
    color: #f9fafb;
    font-weight: 700;
    box-shadow: 0 0 0 1px rgba(229, 231, 235, 0.15);
  }

  .t-kw   { color: #c084fc; }
  .t-fn   { color: #60a5fa; }
  .t-str  { color: #86efac; }
  .t-num  { color: #fde68a; }
  .t-cmt  { color: #374151; font-style: italic; }
  .t-type { color: #f9a8d4; }
  .t-var  { color: #e5e7eb; }
  .t-op   { color: #94a3b8; }
  .t-prop { color: #93c5fd; }
  .t-anno { color: #fbbf24; }
</style>

