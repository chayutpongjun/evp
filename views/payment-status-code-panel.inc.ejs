<script>
(function () {
  var M = {
    baseUrl:    '<%- BASE_URL %>',
    terminal:   '<%- TERMINAL %>',
    partner:    '<%- PARTNER %>',
    apiKey:     '<%- API_KEY %>',
    evpUrl:     '<%- EVP_URL %>',
    proxyUrl:   '<%- APP_URL %>'
  };

  function esc(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  function vals() {
    var el = document.getElementById('evpPaymentId');
    var id = (el && el.value.trim()) || '{evp_payment_id}';
    return { evpPaymentId: id };
  }

  function evpBasePath() {
    return M.baseUrl.replace(/\/$/, '') + '/v1/terminals/' + M.terminal + '/payments/';
  }

  function rawCurlStatus(v) {
    var tid = M.terminal ? ' \\\n  -H "x-terminal-id: ' + M.terminal + '"' : '';
    return 'curl -X GET ' + M.proxyUrl + '/api/payments/' + encodeURIComponent(v.evpPaymentId) + tid;
  }

  function rawCurlDirectStatus(v) {
    return 'curl -X GET ' + evpBasePath() + encodeURIComponent(v.evpPaymentId) + ' \\\n'
      + '  -H "x-api-key: ' + M.apiKey + '"';
  }

  function rawNodejsStatus(v) {
    var base = M.proxyUrl + '/api/payments/';
    return "const axios = require('axios');\n\nconst paymentId = '" + v.evpPaymentId.replace(/'/g, "\\'") + "';\nconst url = "
      + JSON.stringify(base) + " + paymentId;\n\nasync function getPaymentStatus() {\n"
      + "  const { data } = await axios.get(url, { headers: { 'x-terminal-id': '" + M.terminal + "' } });\n"
      + "  console.log(data);\n}\n\ngetPaymentStatus();\n";
  }

  function rawNodejsEvpStatus(v) {
    var base = evpBasePath();
    return "const axios = require('axios');\n\nconst paymentId = '" + v.evpPaymentId.replace(/'/g, "\\'") + "';\nconst url = "
      + JSON.stringify(base) + " + paymentId;\n\nasync function getPaymentStatus() {\n"
      + "  const { data } = await axios.get(url, { headers: { 'x-api-key': '" + M.apiKey + "' } });\n"
      + "  console.log(data);\n}\n\ngetPaymentStatus();\n";
  }

  function rawJsStatus(v) {
    var base = M.proxyUrl + '/api/payments/';
    return "const paymentId = '" + v.evpPaymentId.replace(/'/g, "\\'") + "';\nconst url = " + JSON.stringify(base) + " + paymentId;\n\n"
      + "const res = await fetch(url, { headers: { 'x-terminal-id': '" + M.terminal + "' } });\n"
      + "const data = await res.json();\nconsole.log(data);\n";
  }

  function rawJsEvpStatus(v) {
    var base = evpBasePath();
    return "const paymentId = '" + v.evpPaymentId.replace(/'/g, "\\'") + "';\nconst url = " + JSON.stringify(base) + " + paymentId;\n\n"
      + "const res = await fetch(url, { headers: { 'x-api-key': '" + M.apiKey + "' } });\n"
      + "const data = await res.json();\nconsole.log(data);\n";
  }

  function rawPythonStatus(v) {
    var base = M.proxyUrl + '/api/payments/';
    return 'import requests\n\npayment_id = "' + v.evpPaymentId.replace(/"/g, '\\"') + '"\nurl = "' + base + '" + payment_id\n\n'
      + 'response = requests.get(url, headers={"x-terminal-id": "' + M.terminal + '"})\nprint(response.json())\n';
  }

  function rawPythonEvpStatus(v) {
    var base = evpBasePath();
    return 'import requests\n\npayment_id = "' + v.evpPaymentId.replace(/"/g, '\\"') + '"\nurl = "' + base + '" + payment_id\n\n'
      + 'response = requests.get(url, headers={"x-api-key": "' + M.apiKey + '"})\nprint(response.json())\n';
  }

  function rawCsharpStatus(v) {
    var base = M.proxyUrl + '/api/payments/';
    return 'using System.Net.Http;\n\nvar client = new HttpClient();\nclient.DefaultRequestHeaders.Add("x-terminal-id", "' + M.terminal + '");\n'
      + 'var paymentId = "' + v.evpPaymentId.replace(/"/g, '\\"') + '";\nvar url = "' + base + '" + paymentId;\n\nvar response = await client.GetAsync(url);\n'
      + 'var result = await response.Content.ReadAsStringAsync();\nConsole.WriteLine(result);\n';
  }

  function rawCsharpEvpStatus(v) {
    var base = evpBasePath();
    return 'using System.Net.Http;\n\nvar client = new HttpClient();\n'
      + 'client.DefaultRequestHeaders.Add("x-api-key", "' + M.apiKey + '");\n'
      + 'var paymentId = "' + v.evpPaymentId.replace(/"/g, '\\"') + '";\nvar url = "' + base + '" + paymentId;\n\n'
      + 'var response = await client.GetAsync(url);\nvar result = await response.Content.ReadAsStringAsync();\nConsole.WriteLine(result);\n';
  }

  function rawCppStatus(v) {
    var base = M.proxyUrl + '/api/payments/';
    return '#include <iostream>\n#include <string>\n#include <curl/curl.h>\n\nstatic size_t WriteCallback(void* c, size_t s, size_t n, std::string* b) { b->append((char*)c, s*n); return s*n; }\n\nint main() {\n'
      + '    std::string paymentId = "' + v.evpPaymentId.replace(/"/g, '\\"') + '";\n'
      + '    std::string url = "' + base + '" + paymentId;\n'
      + '    CURL* curl = curl_easy_init();\n    std::string resp;\n    if (curl) {\n'
      + '        struct curl_slist* hdrs = nullptr;\n'
      + '        hdrs = curl_slist_append(hdrs, "x-terminal-id: ' + M.terminal + '");\n'
      + '        curl_easy_setopt(curl, CURLOPT_URL, url.c_str());\n'
      + '        curl_easy_setopt(curl, CURLOPT_HTTPGET, 1L);\n'
      + '        curl_easy_setopt(curl, CURLOPT_HTTPHEADER, hdrs);\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, WriteCallback);\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEDATA, &resp);\n'
      + '        curl_easy_perform(curl);\n        curl_easy_cleanup(curl);\n    }\n'
      + '    std::cout << resp << std::endl;\n    return 0;\n}';
  }

  function rawCppEvpStatus(v) {
    var base = evpBasePath();
    return '#include <iostream>\n#include <string>\n#include <curl/curl.h>\n\nstatic size_t WriteCallback(void* c, size_t s, size_t n, std::string* b) { b->append((char*)c, s*n); return s*n; }\n\nint main() {\n'
      + '    std::string paymentId = "' + v.evpPaymentId.replace(/"/g, '\\"') + '";\n    std::string url = "' + base + '" + paymentId;\n'
      + '    CURL* curl = curl_easy_init();\n    std::string resp;\n    if (curl) {\n'
      + '        struct curl_slist* hdrs = nullptr;\n'
      + '        hdrs = curl_slist_append(hdrs, "x-api-key: ' + M.apiKey + '");\n'
      + '        curl_easy_setopt(curl, CURLOPT_URL, url.c_str());\n'
      + '        curl_easy_setopt(curl, CURLOPT_HTTPGET, 1L);\n'
      + '        curl_easy_setopt(curl, CURLOPT_HTTPHEADER, hdrs);\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, WriteCallback);\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEDATA, &resp);\n'
      + '        curl_easy_perform(curl);\n        curl_easy_cleanup(curl);\n    }\n'
      + '    std::cout << resp << std::endl;\n    return 0;\n}';
  }

  function rawPhpStatus(v) {
    var base = M.proxyUrl + '/api/payments/';
    return "<?php\n\n$paymentId = '" + v.evpPaymentId.replace(/'/g, "\\'") + "';\n$url = '" + base + "' . $paymentId;\n\n"
      + "$ch = curl_init($url);\ncurl_setopt_array($ch, [\n    CURLOPT_RETURNTRANSFER => true,\n"
      + "    CURLOPT_HTTPHEADER => ['x-terminal-id: " + M.terminal + "']\n]);\n\n"
      + "$response = curl_exec($ch);\ncurl_close($ch);\necho $response;\n";
  }

  function rawPhpEvpStatus(v) {
    var base = evpBasePath();
    return "<?php\n\n$paymentId = '" + v.evpPaymentId.replace(/'/g, "\\'") + "';\n$url = '" + base + "' . $paymentId;\n\n"
      + "$ch = curl_init($url);\ncurl_setopt_array($ch, [\n    CURLOPT_RETURNTRANSFER => true,\n"
      + "    CURLOPT_HTTPHEADER => ['x-api-key: " + M.apiKey + "']\n]);\n\n"
      + "$response = curl_exec($ch);\ncurl_close($ch);\necho $response;\n";
  }

  function rawHtmlStatus(v) {
    var base = M.proxyUrl + '/api/payments/';
    return '<!DOCTYPE html>\n<html><head><meta charset="UTF-8"></head><body>\n<button onclick="loadStatus()">Get status</button>\n<pre id="r"></pre>\n<script>\nasync function loadStatus() {\n  const paymentId = \'' + v.evpPaymentId.replace(/'/g, "\\'") + '\';\n  const url = ' + JSON.stringify(base) + ' + paymentId;\n  const res = await fetch(url, { headers: { "x-terminal-id": "' + M.terminal + '" } });\n  document.getElementById("r").textContent = JSON.stringify(await res.json(), null, 2);\n}\n<\/script></body></html>';
  }

  function rawHtmlEvpStatus(v) {
    var base = evpBasePath();
    return '<!DOCTYPE html>\n<html><head><meta charset="UTF-8"></head><body>\n<button onclick="loadStatus()">Get status</button>\n<pre id="r"></pre>\n<script>\nasync function loadStatus() {\n  const paymentId = \'' + v.evpPaymentId.replace(/'/g, "\\'") + '\';\n  const url = ' + JSON.stringify(base) + ' + paymentId;\n  const res = await fetch(url, { headers: { "x-api-key": "' + M.apiKey + '" } });\n  document.getElementById("r").textContent = JSON.stringify(await res.json(), null, 2);\n}\n<\/script></body></html>';
  }

  function genCurlStatus(v) {
    var idEsc = esc(v.evpPaymentId);
    var statusUrl = esc(M.proxyUrl) + '/api/payments/' + idEsc;
    var tidLine = M.terminal
