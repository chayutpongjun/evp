      '<span class="t-op">&lt;</span><span class="t-kw">button</span> <span class="t-prop">onclick</span>=<span class="t-str">"loadStatus()"</span><span class="t-op">&gt;</span>Get status<span class="t-op">&lt;/</span><span class="t-kw">button</span><span class="t-op">&gt;</span>',
      '<span class="t-op">&lt;</span><span class="t-kw">pre</span> <span class="t-prop">id</span>=<span class="t-str">"r"</span><span class="t-op">&gt;&lt;/</span><span class="t-kw">pre</span><span class="t-op">&gt;</span>',
      '<span class="t-op">&lt;</span><span class="t-kw">script</span><span class="t-op">&gt;</span>',
      '<span class="t-kw">async function</span> <span class="t-fn">loadStatus</span>() {',
      '  <span class="t-kw">const</span> <span class="t-var">paymentId</span> = <span class="t-str">\'' + pidEsc + '\'</span>;',
      '  <span class="t-kw">const</span> <span class="t-var">url</span> = <span class="t-str">\'' + u + '\'</span> + <span class="t-var">paymentId</span>;',
      '  <span class="t-kw">const</span> <span class="t-var">res</span> = <span class="t-kw">await</span> <span class="t-fn">fetch</span>(<span class="t-var">url</span>, {',
      '    <span class="t-prop">headers</span>: { <span class="t-str">\'x-terminal-id\'</span>: <span class="t-str">\'' + esc(M.terminal) + '\'</span> }',
      '  });',
      '  <span class="t-var">document</span>.<span class="t-fn">getElementById</span>(<span class="t-str">\'r\'</span>).<span class="t-prop">textContent</span> = <span class="t-type">JSON</span>.<span class="t-fn">stringify</span>(<span class="t-kw">await</span> <span class="t-var">res</span>.<span class="t-fn">json</span>(), <span class="t-kw">null</span>, <span class="t-num">2</span>);',
      '}',
      '<span class="t-op">&lt;/</span><span class="t-kw">script</span><span class="t-op">&gt;&lt;/</span><span class="t-kw">body</span><span class="t-op">&gt;&lt;/</span><span class="t-kw">html</span><span class="t-op">&gt;</span>'
    ].join('\n');
  }

  function genHtmlEvpStatus(v) {
    var u = esc(evpBasePath());
    var pidEsc = esc(v.evpPaymentId);
    return [
      '<span class="t-op">&lt;!</span><span class="t-kw">DOCTYPE</span> <span class="t-type">html</span><span class="t-op">&gt;</span>',
      '<span class="t-op">&lt;</span><span class="t-kw">html</span><span class="t-op">&gt;&lt;</span><span class="t-kw">head</span><span class="t-op">&gt;&lt;</span><span class="t-kw">meta</span> <span class="t-prop">charset</span>=<span class="t-str">"UTF-8"</span><span class="t-op">&gt;&lt;/</span><span class="t-kw">head</span><span class="t-op">&gt;&lt;</span><span class="t-kw">body</span><span class="t-op">&gt;</span>',
      '<span class="t-op">&lt;</span><span class="t-kw">button</span> <span class="t-prop">onclick</span>=<span class="t-str">"loadStatus()"</span><span class="t-op">&gt;</span>Get status<span class="t-op">&lt;/</span><span class="t-kw">button</span><span class="t-op">&gt;</span>',
      '<span class="t-op">&lt;</span><span class="t-kw">pre</span> <span class="t-prop">id</span>=<span class="t-str">"r"</span><span class="t-op">&gt;&lt;/</span><span class="t-kw">pre</span><span class="t-op">&gt;</span>',
      '<span class="t-op">&lt;</span><span class="t-kw">script</span><span class="t-op">&gt;</span>',
      '<span class="t-kw">async function</span> <span class="t-fn">loadStatus</span>() {',
      '  <span class="t-kw">const</span> <span class="t-var">paymentId</span> = <span class="t-str">\'' + pidEsc + '\'</span>;',
      '  <span class="t-kw">const</span> <span class="t-var">url</span> = <span class="t-str">\'' + u + '\'</span> + <span class="t-var">paymentId</span>;',
      '  <span class="t-kw">const</span> <span class="t-var">res</span> = <span class="t-kw">await</span> <span class="t-fn">fetch</span>(<span class="t-var">url</span>, {',
      '    <span class="t-prop">headers</span>: { <span class="t-str">\'x-api-key\'</span>: <span class="t-str">\'' + esc(M.apiKey) + '\'</span> }',
      '  });',
      '  <span class="t-var">document</span>.<span class="t-fn">getElementById</span>(<span class="t-str">\'r\'</span>).<span class="t-prop">textContent</span> = <span class="t-type">JSON</span>.<span class="t-fn">stringify</span>(<span class="t-kw">await</span> <span class="t-var">res</span>.<span class="t-fn">json</span>(), <span class="t-kw">null</span>, <span class="t-num">2</span>);',
      '}',
      '<span class="t-op">&lt;/</span><span class="t-kw">script</span><span class="t-op">&gt;&lt;/</span><span class="t-kw">body</span><span class="t-op">&gt;&lt;/</span><span class="t-kw">html</span><span class="t-op">&gt;</span>'
    ].join('\n');
  }

  var genFns = {
    curl: {
      proxy:  function (v) { return genCurlStatus(v); },
      direct: function (v) { return genCurlDirectStatus(v); }
    },
    nodejs: {
      proxy:  function (v) { return genNodejsStatus(v); },
      direct: function (v) { return genNodejsEvpStatus(v); }
    },
    js: {
      proxy:  function (v) { return genJsStatus(v); },
      direct: function (v) { return genJsEvpStatus(v); }
    },
    python: {
      proxy:  function (v) { return genPythonStatus(v); },
      direct: function (v) { return genPythonEvpStatus(v); }
    },
    csharp: {
      proxy:  function (v) { return genCsharpStatus(v); },
      direct: function (v) { return genCsharpEvpStatus(v); }
    },
    cpp: {
      proxy:  function (v) { return genCppStatus(v); },
      direct: function (v) { return genCppEvpStatus(v); }
    },
    php: {
      proxy:  function (v) { return genPhpStatus(v); },
      direct: function (v) { return genPhpEvpStatus(v); }
    },
    html: {
      proxy:  function (v) { return genHtmlStatus(v); },
      direct: function (v) { return genHtmlEvpStatus(v); }
    }
  };

  var rawFns = {
    curl: {
      proxy:  function (v) { return rawCurlStatus(v); },
      direct: function (v) { return rawCurlDirectStatus(v); }
    },
    nodejs: {
      proxy:  function (v) { return rawNodejsStatus(v); },
      direct: function (v) { return rawNodejsEvpStatus(v); }
    },
    js: {
      proxy:  function (v) { return rawJsStatus(v); },
      direct: function (v) { return rawJsEvpStatus(v); }
    },
    python: {
      proxy:  function (v) { return rawPythonStatus(v); },
      direct: function (v) { return rawPythonEvpStatus(v); }
    },
    csharp: {
      proxy:  function (v) { return rawCsharpStatus(v); },
      direct: function (v) { return rawCsharpEvpStatus(v); }
    },
    cpp: {
      proxy:  function (v) { return rawCppStatus(v); },
      direct: function (v) { return rawCppEvpStatus(v); }
    },
    php: {
      proxy:  function (v) { return rawPhpStatus(v); },
      direct: function (v) { return rawPhpEvpStatus(v); }
    },
    html: {
      proxy:  function (v) { return rawHtmlStatus(v); },
      direct: function (v) { return rawHtmlEvpStatus(v); }
    }
  };

  var activeLang = 'curl';
  var activeCodeEx = 'proxy';

  function setCodeExMode(mode) {
    activeCodeEx = mode;
    document.querySelectorAll('[data-code-ex]').forEach(function (t) {
      t.classList.toggle('active', t.getAttribute('data-code-ex') === mode);
    });
    ['curl','nodejs','js','python','csharp','cpp','php','html'].forEach(function (lang) {
      var p = document.getElementById('code-' + lang + '-proxy');
      var d = document.getElementById('code-' + lang + '-direct');
      if (p) p.style.display = mode === 'proxy' ? '' : 'none';
      if (d) d.style.display = mode === 'direct' ? '' : 'none';
    });
  }

  function updateCode() {
    var v = vals();
    ['curl','nodejs','js','python','csharp','cpp','php','html'].forEach(function (lang) {
      var pe = document.getElementById('code-' + lang + '-proxy');
      var de = document.getElementById('code-' + lang + '-direct');
      var g = genFns[lang];
      if (g && pe) pe.innerHTML = g.proxy(v);
      if (g && de) de.innerHTML = g.direct(v);
    });
  }

  document.querySelectorAll('.lang-tab').forEach(function (tab) {
    tab.addEventListener('click', function () {
      document.querySelectorAll('.lang-tab').forEach(function (t) { t.classList.remove('active'); });
      document.querySelectorAll('.lang-body').forEach(function (b) { b.classList.remove('active'); });
      tab.classList.add('active');
      activeLang = tab.getAttribute('data-lang');
      var body = document.getElementById('lang-' + activeLang);
      if (body) body.classList.add('active');
    });
  });

  document.querySelectorAll('[data-code-ex]').forEach(function (st) {
    st.addEventListener('click', function () {
      setCodeExMode(st.getAttribute('data-code-ex'));
    });
  });

  document.querySelectorAll('.code-copy-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var targetId = btn.getAttribute('data-target');
      var lang = targetId ? targetId.replace('code-', '') : activeLang;
      var v = vals();
      var raw = '';
      if (rawFns[lang] && rawFns[lang][activeCodeEx]) {
        raw = rawFns[lang][activeCodeEx](v);
      }
      if (!raw) return;
      navigator.clipboard.writeText(raw).then(function () {
        btn.classList.add('copied');
        var orig = btn.innerHTML;
        btn.innerHTML = btn.innerHTML.replace(/Copy/i, 'Copied!');
        setTimeout(function () { btn.classList.remove('copied'); btn.innerHTML = orig; }, 1800);
      });
    });
  });

  var pidInput = document.getElementById('evpPaymentId');
  if (pidInput) pidInput.addEventListener('input', updateCode);
  var pickEl = document.getElementById('paymentPick');
  if (pickEl) pickEl.addEventListener('change', function () { setTimeout(updateCode, 50); });

  updateCode();
})();
</script>
