  var rawSepGwJs = '\n\n// --- Get payment status (Gateway) ---\n\n';
  var rawSepGw = '\n\n# --- Get payment status (Gateway) ---\n\n';

  function rawCurlGatewayCreate(v) {
    var body = JSON.stringify({
      amount:         v.amount,
      currCode:       v.currCode,
      orderId:        v.orderId,
      customerId:     v.customerId,
      transactionRef: v.txnRef
    }, null, 2);
    var tidLine = M.terminal ? '  -H "x-terminal-id: ' + M.terminal + '" \\\n' : '';
    return 'curl -X POST ' + M.proxyUrl + ' \\\n'
      + '  -H "Content-Type: application/json" \\\n'
      + tidLine
      + '  -d \'' + body + '\'';
  }
  function rawCurlGatewayStatus(v) {
    var tid = M.terminal ? ' \\\n  -H "x-terminal-id: ' + M.terminal + '"' : '';
    return 'curl -X GET ' + M.proxyUrl + '/{evp_payment_id}' + tid;
  }
  function rawNodejsGatewayStatus(v) {
    var base = M.proxyUrl + '/';
    return "const axios = require('axios');\n\nconst paymentId = '{evp_payment_id}';\nconst url = "
      + JSON.stringify(base) + " + paymentId;\n\nasync function getPaymentStatus() {\n"
      + "  const { data } = await axios.get(url, { headers: { 'x-terminal-id': '" + M.terminal + "' } });\n"
      + "  console.log(data);\n}\n\ngetPaymentStatus();\n";
  }
  function rawJsGatewayStatus(v) {
    var base = M.proxyUrl + '/';
    return "const paymentId = '{evp_payment_id}';\nconst url = " + JSON.stringify(base) + " + paymentId;\n\n"
      + "const res = await fetch(url, { headers: { 'x-terminal-id': '" + M.terminal + "' } });\n"
      + "const data = await res.json();\nconsole.log(data);\n";
  }
  function rawPythonGatewayStatus(v) {
    var base = M.proxyUrl + '/';
    return 'import requests\n\npayment_id = "{evp_payment_id}"\nurl = "' + base + '" + payment_id\n\n'
      + 'response = requests.get(url, headers={"x-terminal-id": "' + M.terminal + '"})\nprint(response.json())\n';
  }
  function rawCsharpGatewayStatus(v) {
    var base = M.proxyUrl + '/';
    return 'using System.Net.Http;\n\nvar client = new HttpClient();\nclient.DefaultRequestHeaders.Add("x-terminal-id", "' + M.terminal + '");\n'
      + 'var paymentId = "{evp_payment_id}";\nvar url = "' + base + '" + paymentId;\n\n'
      + 'var response = await client.GetAsync(url);\nvar result = await response.Content.ReadAsStringAsync();\nConsole.WriteLine(result);\n';
  }
  function rawCppGatewayStatus(v) {
    var base = M.proxyUrl + '/';
    return '#include <iostream>\n#include <string>\n#include <curl/curl.h>\n\nstatic size_t WriteCallback(void* c, size_t s, size_t n, std::string* b) { b->append((char*)c, s*n); return s*n; }\n\nint main() {\n'
      + '    std::string paymentId = "{evp_payment_id}";\n    std::string url = "' + base + '" + paymentId;\n'
      + '    CURL* curl = curl_easy_init();\n    std::string resp;\n    if (curl) {\n'
      + '        struct curl_slist* hdrs = nullptr;\n'
      + '        hdrs = curl_slist_append(hdrs, "x-terminal-id: ' + M.terminal + '");\n'
      + '        curl_easy_setopt(curl, CURLOPT_URL, url.c_str());\n'
      + '        curl_easy_setopt(curl, CURLOPT_HTTPGET, 1L);\n'
      + '        curl_easy_setopt(curl, CURLOPT_HTTPHEADER, hdrs);\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEFUNCTION, WriteCallback);\n'
      + '        curl_easy_setopt(curl, CURLOPT_WRITEDATA, &resp);\n'
      + '        curl_easy_perform(curl);\n        curl_easy_cleanup(curl);\n    }\n'
      + '    std::cout << resp << std::endl;\n    return 0;\n}';
  }
  function rawPhpGatewayStatus(v) {
    var base = M.proxyUrl + '/';
    return "<?php\n\n$paymentId = '{evp_payment_id}';\n$url = '" + base + "' . $paymentId;\n\n"
      + "$ch = curl_init($url);\ncurl_setopt_array($ch, [\n    CURLOPT_RETURNTRANSFER => true,\n"
      + "    CURLOPT_HTTPHEADER => ['x-terminal-id: " + M.terminal + "']\n]);\n\n"
      + "$response = curl_exec($ch);\ncurl_close($ch);\necho $response;\n";
  }
  function rawHtmlGatewayStatus(v) {
    var base = M.proxyUrl + '/';
    return '<!DOCTYPE html>\n<html><head><meta charset="UTF-8"></head><body>\n<button onclick="loadStatus()">Get status</button>\n<pre id="r"></pre>\n<script>\nasync function loadStatus() {\n  const paymentId = \'{evp_payment_id}\';\n  const url = ' + JSON.stringify(base) + ' + paymentId;\n  const res = await fetch(url, { headers: { "x-terminal-id": "' + M.terminal + '" } });\n  document.getElementById("r").textContent = JSON.stringify(await res.json(), null, 2);\n}\n<\/script></body></html>';
  }

  var rawFns = {
    curl:   function (v) { return rawCurlGatewayCreate(v) + rawSepGw + rawCurlGatewayStatus(v); },
    nodejs: function (v) { return rawNodejs(v) + rawSepGwJs + rawNodejsGatewayStatus(v); },
    js:     function (v) { return rawJs(v) + rawSepGwJs + rawJsGatewayStatus(v); },
    python: function (v) { return rawPython(v) + rawSepGwJs + rawPythonGatewayStatus(v); },
    csharp: function (v) { return rawCsharp(v) + rawSepGwJs + rawCsharpGatewayStatus(v); },
    cpp:    function (v) { return rawCpp(v) + rawSepGwJs + rawCppGatewayStatus(v); },
    php:    function (v) { return rawPhp(v) + rawSepGwJs + rawPhpGatewayStatus(v); },
    html:   function (v) { return rawHtml(v) + rawSepGwJs + rawHtmlGatewayStatus(v); }
  };

  var genFns = {
    curl:   function (v) { return genCurlGatewayCreate(v) + sepGwCurl + genCurlGatewayStatus(v); },
    nodejs: function (v) { return genNodejs(v) + sepGwCode + genNodejsGatewayStatus(v); },
    js:     function (v) { return genJs(v) + sepGwCode + genJsGatewayStatus(v); },
    python: function (v) { return genPython(v) + sepGwCode + genPythonGatewayStatus(v); },
    csharp: function (v) { return genCsharp(v) + sepGwCode + genCsharpGatewayStatus(v); },
    cpp:    function (v) { return genCpp(v) + sepGwCode + genCppGatewayStatus(v); },
    php:    function (v) { return genPhp(v) + sepGwCode + genPhpGatewayStatus(v); },
    html:   function (v) { return genHtml(v) + sepGwCode + genHtmlGatewayStatus(v); }
  };

  var activeLang = 'curl';

  function updateCode() {
    var v = vals();
    ['curl','nodejs','js','python','csharp','cpp','php','html'].forEach(function (lang) {
      var el = document.getElementById('code-' + lang);
      var g = genFns[lang];
      if (el && g) el.innerHTML = g(v);
    });
  }

  /* tab switching */
  document.querySelectorAll('.lang-tab').forEach(function (tab) {
    tab.addEventListener('click', function () {
      document.querySelectorAll('.lang-tab').forEach(function (t) { t.classList.remove('active'); });
      document.querySelectorAll('.lang-body').forEach(function (b) { b.classList.remove('active'); });
      tab.classList.add('active');
      activeLang = tab.getAttribute('data-lang');
      var body = document.getElementById('lang-' + activeLang);
      if (body) body.classList.add('active');
    });
  });

  /* copy buttons */
  document.querySelectorAll('.code-copy-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var targetId = btn.getAttribute('data-target');
      var lang = targetId ? targetId.replace('code-', '') : activeLang;
      var v = vals();
      var raw = '';
      if (rawFns[lang]) {
        raw = rawFns[lang](v);
      }
      if (!raw) return;
      navigator.clipboard.writeText(raw).then(function () {
        btn.classList.add('copied');
        var orig = btn.innerHTML;
        btn.innerHTML = btn.innerHTML.replace(/Copy/i, 'Copied!');
        setTimeout(function () { btn.classList.remove('copied'); btn.innerHTML = orig; }, 1800);
      });
    });
  });

  /* live update on form change */
  ['f_amount','f_currCode','f_orderId','f_customerId','f_transactionRef'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) el.addEventListener('input', updateCode);
  });

  /* initial render */
  updateCode();
})();
</script>

