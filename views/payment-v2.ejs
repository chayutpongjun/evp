  /* plain-text version for copying (proxy payload) */
  function rawProxyPayload(v) {
    return {
      amount:         Number(v.amount)   || 0,
      currCode:       Number(v.currCode) || 764,
      orderId:        v.orderId,
      customerId:     v.customerId,
      transactionRef: v.txnRef
    };
  }

