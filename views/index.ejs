<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <title>เข้าสู่ระบบ · EVP Gateway</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --bg: #0b1020;
        --stroke: rgba(148, 163, 184, 0.14);
        --text: #e5e7eb;
        --muted: #94a3b8;
        --brand1: #4f46e5;
        --brand2: #22c55e;
        --bad: #f87171;
        --card: rgba(2, 6, 23, 0.72);
      }
      * {
        box-sizing: border-box;
      }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: 'DM Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: var(--bg);
        color: var(--text);
        overflow-x: hidden;
      }
      .bg {
        position: fixed;
        inset: 0;
        z-index: 0;
        background:
          radial-gradient(1200px 700px at 10% -10%, rgba(79, 70, 229, 0.38), transparent 60%),
          radial-gradient(900px 500px at 85% 0%, rgba(34, 197, 94, 0.22), transparent 55%),
          radial-gradient(800px 600px at 45% 110%, rgba(14, 165, 233, 0.12), transparent 55%),
          var(--bg);
      }
      .bg::after {
        content: '';
        position: absolute;
        inset: 0;
        background-image: linear-gradient(rgba(148, 163, 184, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(148, 163, 184, 0.04) 1px, transparent 1px);
        background-size: 48px 48px;
        mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, black 20%, transparent 70%);
        pointer-events: none;
      }
      .wrap {
        position: relative;
        z-index: 1;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 32px 20px 48px;
      }
      .panel {
        width: 100%;
        max-width: 440px;
      }
      .brand-row {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
      }
      .logo {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
        box-shadow:
          0 0 28px rgba(79, 70, 229, 0.45),
          0 8px 24px rgba(0, 0, 0, 0.35);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .logo svg {
        width: 26px;
        height: 26px;
      }
      .brand-text h1 {
        margin: 0;
        font-size: 1.35rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.2;
      }
      .brand-text p {
        margin: 4px 0 0;
        font-size: 0.8125rem;
        color: var(--muted);
        font-weight: 500;
      }
      .card {
        border-radius: 20px;
        border: 1px solid var(--stroke);
        background: var(--card);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow:
          0 24px 80px rgba(0, 0, 0, 0.45),
          inset 0 1px 0 rgba(255, 255, 255, 0.04);
        padding: 28px 26px 24px;
      }
      .card-head {
        margin-bottom: 22px;
      }
      .card-head h2 {
        margin: 0 0 6px;
        font-size: 1.125rem;
        font-weight: 600;
        letter-spacing: -0.01em;
      }
      .card-head span {
        font-size: 0.8125rem;
        color: var(--muted);
        line-height: 1.45;
      }
      .alert {
        display: flex;
        gap: 10px;
        align-items: flex-start;
        padding: 11px 13px;
        border-radius: 12px;
        margin-bottom: 18px;
        font-size: 0.8125rem;
        line-height: 1.45;
        border: 1px solid rgba(248, 113, 113, 0.25);
        background: rgba(127, 29, 29, 0.22);
        color: #fecaca;
      }
      .alert svg {
        flex-shrink: 0;
        margin-top: 1px;
        opacity: 0.9;
      }
      .field {
        margin-bottom: 16px;
      }
      .field:last-of-type {
        margin-bottom: 0;
      }
      label {
        display: block;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: rgba(148, 163, 184, 0.85);
        margin-bottom: 7px;
      }
      .input-wrap {
        position: relative;
      }
      .input-wrap svg {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        width: 18px;
        height: 18px;
        color: rgba(148, 163, 184, 0.55);
        pointer-events: none;
      }
      input {
        width: 100%;
        padding: 12px 14px 12px 44px;
        font-size: 0.9375rem;
        font-family: inherit;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        background: rgba(2, 6, 23, 0.65);
        color: var(--text);
        outline: none;
        transition:
          border-color 0.15s,
          box-shadow 0.15s;
      }
      input::placeholder {
        color: rgba(148, 163, 184, 0.45);
      }
      input:focus {
        border-color: rgba(79, 70, 229, 0.55);
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.18);
      }
      .btn {
        width: 100%;
        margin-top: 22px;
        padding: 13px 18px;
        border: none;
        border-radius: 999px;
        font-family: inherit;
        font-size: 0.9375rem;
        font-weight: 700;
        cursor: pointer;
        color: #fff;
        background: linear-gradient(135deg, var(--brand1), var(--brand2));
        box-shadow:
          0 4px 20px rgba(79, 70, 229, 0.35),
          0 2px 8px rgba(0, 0, 0, 0.2);
        transition:
          transform 0.12s,
          box-shadow 0.12s,
          filter 0.12s;
      }
      .btn:hover {
        filter: brightness(1.06);
        box-shadow:
          0 6px 28px rgba(79, 70, 229, 0.45),
          0 2px 10px rgba(0, 0, 0, 0.25);
      }
      .btn:active {
        transform: scale(0.98);
      }
      .foot {
        margin-top: 20px;
        padding-top: 18px;
        border-top: 1px solid rgba(148, 163, 184, 0.1);
        text-align: center;
        font-size: 0.6875rem;
        color: rgba(148, 163, 184, 0.55);
        line-height: 1.5;
      }
      .foot code {
        font-size: 0.8125rem;
        color: rgba(148, 163, 184, 0.75);
        background: rgba(2, 6, 23, 0.5);
        padding: 2px 6px;
        border-radius: 6px;
        border: 1px solid rgba(148, 163, 184, 0.12);
      }
    </style>
  </head>
  <body>
    <div class="bg" aria-hidden="true"></div>
    <div class="wrap">
      <div class="panel">
        <div class="brand-row">
          <div class="logo" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="white" xmlns="http://www.w3.org/2000/svg">
              <path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z" />
            </svg>
          </div>
          <div class="brand-text">
            <h1>Visto · EVP Gateway</h1>
            <p>Payment Demo · Webhook · Admin</p>
          </div>
        </div>

        <div class="card">
          <div class="card-head">
            <h2>เข้าสู่ระบบ</h2>
            <span>ใช้บัญชีที่กำหนดในระบบเพื่อเข้าใช้งานแดชบอร์ด</span>
          </div>

          <% if (typeof loginError !== 'undefined' && loginError) { %>
            <div class="alert" role="alert">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" y1="8" x2="12" y2="12" />
                <line x1="12" y1="16" x2="12.01" y2="16" />
              </svg>
              <span>
                <% if (loginErrorBad) { %>
                  ชื่อผู้ใช้หรือรหัสผ่านไม่ถูกต้อง กรุณาลองใหม่
                <% } else { %>
                  กรุณาเข้าสู่ระบบก่อนใช้งานหน้านั้น
                <% } %>
              </span>
            </div>
          <% } %>

          <form id="loginForm" method="post" action="/login" autocomplete="on">
            <div class="field">
              <label for="loginUser">ชื่อผู้ใช้</label>
              <div class="input-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
                <input
                  name="username"
                  id="loginUser"
                  autocomplete="username"
                  placeholder="username"
                  required
                />
              </div>
            </div>
            <div class="field">
              <label for="loginPass">รหัสผ่าน</label>
              <div class="input-wrap">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                  <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                </svg>
                <input
                  name="password"
                  id="loginPass"
                  type="password"
                  autocomplete="current-password"
                  placeholder="••••••••"
                  required
                />
              </div>
            </div>
            <button type="submit" class="btn" id="loginBtn">เข้าสู่ระบบ</button>
          </form>

          <p class="foot">
            ค่าเริ่มต้นจาก <code>APP_LOGIN_USER</code> และ <code>APP_LOGIN_PASSWORD</code> ใน <code>.env</code>
          </p>
        </div>
      </div>
    </div>
  </body>
</html>
