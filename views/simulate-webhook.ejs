<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Simulate EVP Webhook</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        margin: 0;
        padding: 0;
        background: #0f172a;
        color: #e5e7eb;
      }
      .container {
        max-width: 980px;
        margin: 0 auto;
        padding: 24px 16px 64px;
      }
      .card {
        background: #020617;
        border-radius: 12px;
        padding: 16px 18px;
        border: 1px solid #1f2937;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.7);
      }
      h1 {
        font-size: 22px;
        margin: 0 0 10px;
      }
      p,
      label {
        color: #9ca3af;
        font-size: 13px;
      }
      textarea {
        width: 100%;
        min-height: 280px;
        padding: 10px 12px;
        font-size: 13px;
        border-radius: 10px;
        border: 1px solid #374151;
        background: #020617;
        color: #e5e7eb;
        box-sizing: border-box;
        font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New',
          monospace;
      }
      textarea:focus {
        outline: 2px solid #4f46e5;
        outline-offset: 1px;
        border-color: transparent;
      }
      button {
        margin-top: 12px;
        padding: 9px 16px;
        border-radius: 999px;
        border: none;
        background: linear-gradient(135deg, #4f46e5, #22c55e);
        color: white;
        font-weight: 600;
        cursor: pointer;
        font-size: 14px;
      }
      button:disabled {
        opacity: 0.5;
        cursor: progress;
      }
      pre {
        background: #020617;
        padding: 10px 12px;
        border-radius: 10px;
        font-size: 12px;
        max-height: 260px;
        overflow: auto;
        border: 1px solid #111827;
        margin-top: 12px;
      }
      a {
        color: #a5b4fc;
        text-decoration: none;
      }
      .row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
        gap: 14px;
        margin-top: 14px;
      }
      @media (max-width: 900px) {
        .row {
          grid-template-columns: 1fr;
        }
      }
      .chip {
        display: inline-flex;
        gap: 6px;
        align-items: center;
        padding: 2px 10px;
        border-radius: 999px;
        font-size: 12px;
        background: #1f2937;
        color: #93c5fd;
      }
      code {
        color: #93c5fd;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div style="margin-bottom:12px;">
        <a href="/">← Back</a>
      </div>
      <h1>จำลอง Webhook (EVP → Gateway)</h1>
      <p>
        หน้านี้จะยิงไปที่ <span class="chip"><code>POST</code> <code>/api/webhook/evp</code></span>
        โดย payload ต้องมี <code>id</code> หรือ <code>payment_id</code> ให้ตรงกับ <code>Res_Payment_ID</code> ใน
        <code>Tbl_EVPPayment</code>.
      </p>

      <div class="row">
        <div class="card">
          <label>Webhook JSON Payload</label>
          <textarea id="payload"></textarea>
          <button id="sendBtn" type="button">Send Webhook</button>
          <pre id="result">ยังไม่มี</pre>
        </div>
        <div class="card">
          <p style="margin-top:0;">
            ตัวอย่าง (แก้ค่า <code>id</code> ให้เป็น Payment ID ที่มีอยู่ใน DB):
          </p>
          <pre id="sample"></pre>
          <button id="useSampleBtn" type="button">Use sample</button>
        </div>
      </div>
    </div>

    <script>
      const payloadEl = document.getElementById('payload');
      const sendBtn = document.getElementById('sendBtn');
      const resultEl = document.getElementById('result');
      const sampleEl = document.getElementById('sample');
      const useSampleBtn = document.getElementById('useSampleBtn');

      const sample = {
        // Option A: send payment id directly
        // id: "PUT-REAL-RES_PAYMENT_ID-HERE",

        // Option B: reference-only (gateway will lookup Res_Payment_ID then call EVP status)
        order_id: "ORD-TEST-001",
        customer_id: "CUST-003",
        transaction_ref: "TXN-TEST-003",

        // optional extra fields
        status: "PAID",
        paid_at: new Date().toISOString(),
        payment_method: "CARD",
        payment_network: "VISA",
        masked_pan: "411111******1111"
      };

      sampleEl.textContent = JSON.stringify(sample, null, 2);

      useSampleBtn.addEventListener('click', () => {
        payloadEl.value = JSON.stringify(sample, null, 2);
      });

      payloadEl.value = JSON.stringify(sample, null, 2);

      sendBtn.addEventListener('click', async () => {
        let json;
        try {
          json = JSON.parse(payloadEl.value);
        } catch (e) {
          resultEl.textContent = 'Invalid JSON: ' + e.message;
          return;
        }

        sendBtn.disabled = true;
        resultEl.textContent = 'Sending...';

        try {
          const res = await fetch('/api/webhook/evp', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(json)
          });
          const text = await res.text();
          let parsed = null;
          try { parsed = JSON.parse(text); } catch {}
          resultEl.textContent =
            'HTTP ' + res.status + '\\n\\n' + (parsed ? JSON.stringify(parsed, null, 2) : text);
        } catch (e) {
          resultEl.textContent = 'Error: ' + e.message;
        } finally {
          sendBtn.disabled = false;
        }
      });
    </script>
  </body>
</html>

